// SKILL-IOS (P7 #292) — XCTest unit suite for StoreKitManager.
//
// Uses the StoreKit 2 test session API (`SKTestSession`) so the suite
// runs without hitting Apple's real sandbox infrastructure. The
// `Configuration.storekit` test plan binds via the scheme.

import XCTest
import StoreKit
import StoreKitTest
@testable import {{ project_name }}

@MainActor
final class StoreKitManagerTests: XCTestCase {
    var session: SKTestSession!

    override func setUp() async throws {
        try await super.setUp()
        session = try SKTestSession(configurationFileNamed: "Configuration")
        session.disableDialogs = true
        session.clearTransactions()
    }

    override func tearDown() async throws {
        session.clearTransactions()
        session = nil
        try await super.tearDown()
    }

    func testLoadProductsPopulatesCatalogue() async {
        let store = StoreKitManager()
        await store.loadProducts()
        XCTAssertFalse(store.products.isEmpty, "Expected products from StoreKit test plan")
    }

    func testVerificationFailureRejected() {
        let store = StoreKitManager()
        // unverified VerificationResult — synthesized via the StoreKitTest
        // facility in real tests. Here we just check the error type
        // exists and is Equatable, which the protocol relies on.
        XCTAssertNotNil(StoreKitManager.StoreError.verificationFailed("x"))
    }
}
