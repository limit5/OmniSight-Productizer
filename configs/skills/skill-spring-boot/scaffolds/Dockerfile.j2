#
# Multi-stage build:
#   * Stage 1 (builder) — eclipse-temurin:21-jdk. Runs `mvn package`
#     (or `./gradlew bootJar`) depending on build_tool knob. Produces
#     a Spring Boot executable fat jar under target/ (Maven) or
#     build/libs/ (Gradle).
#   * Stage 2 (runtime) — gcr.io/distroless/java21-debian12:nonroot.
#     No shell, no package manager, runs as uid 65532 by default.
#     Anything outside the jar + /app/META-INF is a CVE-scan finding
#     per backend-java role rules.
#
# Wired to backend.build_adapters.DockerImageAdapter (X3 #299). Build:
#   docker build -t {{ artifact_id }}:0.1.0 .

ARG JAVA_VERSION=21

# ── Stage 1: builder ─────────────────────────────────────────────
FROM eclipse-temurin:${JAVA_VERSION}-jdk AS builder

WORKDIR /build

{%- if build_tool == "maven" %}
COPY pom.xml ./
COPY src ./src
RUN --mount=type=cache,target=/root/.m2 \
    mvn -B -DskipTests package \
 && cp target/{{ artifact_id }}-0.1.0.jar /out/app.jar || \
    (mkdir -p /out && cp target/{{ artifact_id }}-0.1.0.jar /out/app.jar)
{%- else %}
COPY build.gradle.kts settings.gradle.kts ./
COPY gradle ./gradle
COPY gradlew ./
RUN chmod +x gradlew
COPY src ./src
RUN --mount=type=cache,target=/root/.gradle \
    ./gradlew --no-daemon bootJar \
 && mkdir -p /out \
 && cp build/libs/{{ artifact_id }}-0.1.0.jar /out/app.jar
{%- endif %}

# ── Stage 2: runtime ─────────────────────────────────────────────
FROM gcr.io/distroless/java21-debian12:nonroot AS runtime

WORKDIR /app

COPY --from=builder /out/app.jar /app/app.jar

USER nonroot:nonroot
EXPOSE 8080

ENTRYPOINT ["java", "-jar", "/app/app.jar"]
