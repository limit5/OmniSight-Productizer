<?xml version="1.0" encoding="UTF-8"?>
<!--
  Generated by SKILL-SPRING-BOOT (X9 #305).

  JSON stdout appender — backend-java role standard. Uses
  LogstashEncoder-style pattern via Spring Boot's built-in JSON
  encoder; avoids pulling logstash-logback-encoder as a transitive.
-->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <appender name="STDOUT_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.JsonEncoder"/>
    </appender>

    <root level="${LOG_LEVEL:-INFO}">
        <appender-ref ref="STDOUT_JSON"/>
    </root>
</configuration>
