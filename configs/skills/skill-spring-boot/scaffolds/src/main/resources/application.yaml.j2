# Generated by SKILL-SPRING-BOOT (X9 #305).

spring:
  application:
    name: {{ artifact_id }}
  profiles:
    active: ${SPRING_PROFILES_ACTIVE:dev}
  threads:
    virtual:
      # JDK 21 virtual threads — backend-java role default-on per
      # role's "virtual threads opt-in" checkbox.
      enabled: true
{%- if database != "none" %}
  datasource:
{%- if database == "postgres" %}
    url: ${SPRING_DATASOURCE_URL:jdbc:postgresql://localhost:5432/{{ artifact_id | replace('-', '_') }}}
    username: ${SPRING_DATASOURCE_USERNAME:{{ artifact_id | replace('-', '_') }}}
    password: ${SPRING_DATASOURCE_PASSWORD:dev-only}
    driver-class-name: org.postgresql.Driver
{%- else %}
    url: ${SPRING_DATASOURCE_URL:jdbc:h2:mem:{{ artifact_id | replace('-', '_') }};DB_CLOSE_DELAY=-1}
    username: ${SPRING_DATASOURCE_USERNAME:sa}
    password: ${SPRING_DATASOURCE_PASSWORD:}
    driver-class-name: org.h2.Driver
{%- endif %}
  jpa:
    hibernate:
      # backend-java anti-pattern guard: `validate` forces schema
      # migrations via Flyway. `update`/`create` would let JPA
      # silently mutate prod.
      ddl-auto: validate
    open-in-view: false
    properties:
      hibernate.jdbc.time_zone: UTC
  flyway:
    enabled: true
    baseline-on-migrate: true
    locations: classpath:db/migration
{%- endif %}

server:
  port: ${SERVER_PORT:8080}
  shutdown: graceful

management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics
  endpoint:
    health:
      probes:
        enabled: true

app:
  name: {{ artifact_id }}
  environment: ${APP_ENVIRONMENT:dev}

logging:
  level:
    root: ${APP_LOG_LEVEL:info}
