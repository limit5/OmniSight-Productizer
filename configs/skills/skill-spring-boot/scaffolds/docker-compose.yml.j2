# Generated by SKILL-SPRING-BOOT (X9 #305).

services:
  {{ artifact_id }}:
    build: .
    image: {{ artifact_id }}:0.1.0
    ports:
      - "8080:8080"
    environment:
      SPRING_PROFILES_ACTIVE: "dev"
      APP_LOG_LEVEL: "info"
{%- if database == "postgres" %}
      SPRING_DATASOURCE_URL: "jdbc:postgresql://postgres:5432/{{ artifact_id | replace('-', '_') }}"
      SPRING_DATASOURCE_USERNAME: "{{ artifact_id | replace('-', '_') }}"
      SPRING_DATASOURCE_PASSWORD: "dev-only"
    depends_on:
      postgres:
        condition: service_healthy

  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: "{{ artifact_id | replace('-', '_') }}"
      POSTGRES_USER: "{{ artifact_id | replace('-', '_') }}"
      POSTGRES_PASSWORD: "dev-only"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ artifact_id | replace('-', '_') }}"]
      interval: 3s
      timeout: 3s
      retries: 10
    ports:
      - "5432:5432"
{%- endif %}
