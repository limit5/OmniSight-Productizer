// P9 #294 — Flutter Android root build.gradle.kts.
//
// All plugins `apply false` — child modules opt in individually. Matches
// the same pattern P8 SKILL-ANDROID uses; keeps the Gradle plugin dag
// predictable across Flutter's auto-injection + our static scaffold.

allprojects {
    repositories {
        google()
        mavenCentral()
    }
}

val newBuildDir: Directory = rootProject.layout.buildDirectory.dir("../../build").get()
rootProject.layout.buildDirectory.value(newBuildDir)

subprojects {
    val newSubprojectBuildDir: Directory = newBuildDir.dir(project.name)
    project.layout.buildDirectory.value(newSubprojectBuildDir)
}

subprojects {
    project.evaluationDependsOn(":app")
}

tasks.register<Delete>("clean") {
    delete(rootProject.layout.buildDirectory)
}
