name: {{ project_name | lower }}
description: "{{ project_name }} — rendered from OmniSight SKILL-FLUTTER (P9 #294)"
publish_to: 'none'
version: 1.0.0+1

environment:
  sdk: ">=3.4.0 <4.0.0"
  flutter: ">=3.22.0"

dependencies:
  flutter:
    sdk: flutter
  cupertino_icons: ^1.0.6
  flutter_riverpod: ^2.5.1
  go_router: ^14.2.0
{% if push %}
  firebase_core: ^3.3.0
  firebase_messaging: ^15.0.4
{% endif %}
{% if payments %}
  in_app_purchase: ^3.2.0
{% endif %}

dev_dependencies:
  flutter_test:
    sdk: flutter
  integration_test:
    sdk: flutter
  flutter_lints: ^4.0.0
  very_good_analysis: ^6.0.0

flutter:
  uses-material-design: true
