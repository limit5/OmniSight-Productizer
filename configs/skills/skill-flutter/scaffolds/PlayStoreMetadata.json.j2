        {
            "sku": "com.example.test.subscription.monthly",
            "billing_period": "P1M",
            "reference_name": "Monthly pro"
        }
    ]{% else %}[]{% endif %},
    "tracks": {
        "internal": {
            "user_fraction": 1.0,
            "release_status": "draft"
        },
        "production": {
            "user_fraction": 0.1,
            "release_status": "draft"
        }
    }
