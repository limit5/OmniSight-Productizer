    "primary_category": "PRODUCTIVITY",
    "content_rating": {
        "rating_scheme": "IARC_GENERIC",
        "rating_label": "EVERYONE",
        "descriptors": []
    },
    "target_audience": {
        "age_group": "ADULTS",
        "appeals_to_children": false
    },
    "data_safety_form_path": "docs/play/data_safety.yaml",
    "privacy_policy_url": "https://example.com/{{ project_name | lower }}/privacy",
