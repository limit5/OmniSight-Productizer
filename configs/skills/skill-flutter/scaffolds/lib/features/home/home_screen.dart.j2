// HomeScreen — Riverpod StateNotifier + Material 3. Reference
// implementation the widget tests exercise.
//
// P4 flutter-dart anti-pattern lock-in:
//   * no `print()` anywhere in business code — `debugPrint` in kDebugMode only.
//   * every async gap is guarded by `mounted` before touching context.
//   * no `setState` for state that escapes a single leaf widget — that's
//     why this screen uses a Riverpod StateNotifier instead.

import 'package:flutter/material.dart';
import 'package:flutter_riverpod/flutter_riverpod.dart';

class CounterState {
  const CounterState({required this.count, required this.lastAction});

  final int count;
  final String lastAction;

  CounterState copyWith({int? count, String? lastAction}) {
    return CounterState(
      count: count ?? this.count,
      lastAction: lastAction ?? this.lastAction,
    );
  }
}

class CounterNotifier extends StateNotifier<CounterState> {
  CounterNotifier() : super(const CounterState(count: 0, lastAction: 'init'));

  void increment() {
    state = state.copyWith(count: state.count + 1, lastAction: 'increment');
  }

  void reset() {
    state = state.copyWith(count: 0, lastAction: 'reset');
  }
}

final counterProvider =
    StateNotifierProvider<CounterNotifier, CounterState>((ref) {
  return CounterNotifier();
});

class HomeScreen extends ConsumerWidget {
  const HomeScreen({super.key});

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final CounterState counter = ref.watch(counterProvider);
    return Scaffold(
      appBar: AppBar(
        title: const Text('{{ project_name }}'),
        actions: <Widget>[
          IconButton(
            key: const Key('reset-counter'),
            icon: const Icon(Icons.refresh),
            tooltip: 'Reset',
            onPressed: () => ref.read(counterProvider.notifier).reset(),
          ),
        ],
      ),
      body: Center(
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: <Widget>[
            Semantics(
              label: 'counter value',
              child: Text(
                '${counter.count}',
                key: const Key('counter-value'),
                style: Theme.of(context).textTheme.displayLarge,
              ),
            ),
            const SizedBox(height: 24),
            Text('last: ${counter.lastAction}'),
          ],
        ),
      ),
      floatingActionButton: FloatingActionButton(
        key: const Key('increment-counter'),
        onPressed: () => ref.read(counterProvider.notifier).increment(),
        tooltip: 'Increment',
        child: const Icon(Icons.add),
      ),
    );
  }
}
