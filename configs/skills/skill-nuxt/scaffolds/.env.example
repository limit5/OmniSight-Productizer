# Generated by SKILL-NUXT (W7 #281).
# Copy to `.env` and fill in real values before running.

# Backend URL (required)
NUXT_BACKEND_URL=http://localhost:8000

# Nitro preset override (optional — scaffolder picks a default)
# NITRO_PRESET=node-server | vercel | cloudflare-pages | bun
# NITRO_PRESET=node-server

# Auth (choose one path)
# sidebase/nuxt-auth:
AUTH_SECRET=replace-me
AUTH_ORIGIN=http://localhost:3000

# Clerk (alternative):
# NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# NUXT_CLERK_SECRET_KEY=

# Database (Drizzle bundle)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nuxt_app

# Email (Postmark bundle)
POSTMARK_SERVER_TOKEN=postmark-server-token
POSTMARK_FROM_EMAIL=Acme <onboarding@example.com>
CONTACT_TO_EMAIL=ops@example.com

# Deploy
# VERCEL_TOKEN=
# CF_API_TOKEN=
# CF_ACCOUNT_ID=
