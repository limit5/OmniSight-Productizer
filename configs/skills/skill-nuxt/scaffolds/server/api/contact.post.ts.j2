// Contact endpoint for the FS.7.2 full-stack bundle.

import { sendContactEmail } from "../email"
{% if drizzle %}import { getDb } from "../db"
import { messages } from "../../drizzle/schema"
{% endif %}
export default defineEventHandler(async (event) => {
  const body = await readBody(event)
  const email = String(body.email || "")
  const subject = String(body.subject || "")
  const message = String(body.message || "")

  if (!email.includes("@") || subject.length < 3 || message.length < 10) {
    setResponseStatus(event, 400)
    return { error: "invalid_contact_request" }
  }

  await sendContactEmail({ fromEmail: email, subject, body: message })
{% if drizzle %}
  await getDb().insert(messages).values({
    email,
    subject,
    body: message,
  })
{% endif %}

  return { ok: true }
})
