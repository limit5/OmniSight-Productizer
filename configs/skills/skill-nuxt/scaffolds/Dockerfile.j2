# Generated by SKILL-NUXT (W7 #281).
# Multi-stage container for Nitro `node-server` preset. The resulting
# image is a lowest-common-denominator deploy target — Render, Fly,
# ECS, and Kubernetes all consume it. Bound to the W1
# `web-ssr-node.yaml` profile; memory footprint aligned to the
# profile's memory_limit_mb.

# ── build stage ──────────────────────────────────────────────
FROM node:20-alpine AS build
WORKDIR /app
COPY package.json ./
RUN npm install --no-audit --no-fund
COPY . .
ENV NITRO_PRESET=node-server
RUN npm run build

# ── runtime stage ────────────────────────────────────────────
FROM node:20-alpine
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
ENV HOST=0.0.0.0
COPY --from=build /app/.output ./.output
EXPOSE 3000
USER node
CMD ["node", ".output/server/index.mjs"]
