//
// Integration tests — exec the built binary via assert_cmd and
// lock the cli-tooling role invariants:
//   * `--version` prints `name semver (sha)`
//   * `--help` exits 0 with usage on stdout
//   * invalid args exit 2 (clap parse error)
//   * `--json` on data subcommand prints parseable JSON on stdout
//   * logs go to stderr, not stdout (pipe-safety)

use assert_cmd::Command;
use predicates::prelude::*;

const BIN: &str = env!("CARGO_PKG_NAME");

#[test]
fn version_flag_prints_semver_and_sha() {
    Command::cargo_bin(BIN)
        .unwrap()
        .arg("--version")
        .assert()
        .success()
        .stdout(predicate::str::contains(env!("CARGO_PKG_VERSION")));
}

#[test]
fn version_subcommand_json_is_parseable() {
    let output = Command::cargo_bin(BIN)
        .unwrap()
        .args(["--json", "version"])
        .assert()
        .success()
        .get_output()
        .stdout
        .clone();
    let parsed: serde_json::Value = serde_json::from_slice(&output)
        .expect("--json version must emit parseable JSON on stdout");
    assert!(parsed.get("name").is_some(), "missing name field");
    assert!(parsed.get("version").is_some(), "missing version field");
    assert!(parsed.get("build_sha").is_some(), "missing build_sha field");
}

#[test]
fn help_exits_zero() {
    Command::cargo_bin(BIN)
        .unwrap()
        .arg("--help")
        .assert()
        .success()
        .stdout(predicate::str::contains("Usage:"));
}

#[test]
fn invalid_flag_exits_two() {
    // Clap's default on parse failure is exit 2 (usage error). This
    // is the contract the cli-tooling role exit-code table pins.
    Command::cargo_bin(BIN)
        .unwrap()
        .arg("--not-a-flag")
        .assert()
        .failure()
        .code(2);
}

