#[test]
fn init_creates_config_json() {
    let tmp = tempfile::tempdir().unwrap();
    let path = tmp.path().join("cfg");
    Command::cargo_bin(BIN)
        .unwrap()
        .args(["--json", "init", "--path"])
        .arg(&path)
        .assert()
        .success();
    assert!(path.join("config.json").exists());
}

#[test]
fn init_refuses_existing_without_force() {
    let tmp = tempfile::tempdir().unwrap();
    let path = tmp.path().join("cfg");
    Command::cargo_bin(BIN)
        .unwrap()
        .args(["init", "--path"])
        .arg(&path)
        .assert()
        .success();
    Command::cargo_bin(BIN)
        .unwrap()
        .args(["init", "--path"])
        .arg(&path)
        .assert()
        .failure()
        .code(1);
}

#[test]
fn json_output_on_stdout_logs_on_stderr() {
    // The cli-tooling role rule "logs → stderr, data → stdout"
    // means `--json status` stdout must be JSON only — any trace
    // line would break `... | jq`.
    let out = Command::cargo_bin(BIN)
        .unwrap()
        .args(["--json", "status"])
        .assert()
        .success()
        .get_output()
        .stdout
        .clone();
    let s = String::from_utf8(out).unwrap();
    // Strip trailing newline; the rest must parse.
    let _: serde_json::Value = serde_json::from_str(s.trim()).unwrap();
}
