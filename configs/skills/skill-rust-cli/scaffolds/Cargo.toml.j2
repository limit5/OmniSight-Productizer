# Generated by SKILL-RUST-CLI (X7 #303).
#
# Rust 2021 edition, stable 1.76+. Binary crate — the one shipped
# artifact is `target/release/{{ bin_name }}`. Aligns with the
# backend-rust / cli-tooling role defaults:
#   * clap 4 derive for argv parsing (no hand-rolled std::env::args)
#   * anyhow for error context / propagation in main
#   * tokio multi-thread runtime for async subcommand work
#   * tracing + tracing-subscriber for structured logs (stderr only)
#   * [profile.release] lto=fat / codegen-units=1 / strip=true for
#     the cli-tooling role "Rust binary ≤ 8 MiB" budget
#   * [workspace.metadata.dist] block consumed by cargo-dist (X3 #299)

[package]
name = "{{ crate_name }}"
version = "0.1.0"
edition = "2021"
rust-version = "1.76"
description = "{{ project_name }} — a Rust CLI scaffolded by SKILL-RUST-CLI"
license = "Apache-2.0"
readme = "README.md"
publish = false

[[bin]]
name = "{{ bin_name }}"
path = "src/main.rs"

[dependencies]
clap = { version = "4.5", features = ["derive", "env", "wrap_help"] }
clap_complete = "4.5"
anyhow = "1.0"
thiserror = "1.0"
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter", "json", "fmt"] }
is-terminal = "0.4"
{%- if runtime == "tokio" %}
tokio = { version = "1", features = ["macros", "rt-multi-thread", "signal", "time", "fs", "io-util"] }
{%- endif %}

[dev-dependencies]
assert_cmd = "2.0"
predicates = "3.1"
tempfile = "3.10"

[build-dependencies]
# build.rs injects GIT_SHA at compile time via cargo:rustc-env.
# No external deps required — it shells out to `git rev-parse`
# with a graceful fallback to the literal string "unknown".

[profile.release]
opt-level = 3
lto = "fat"
codegen-units = 1
strip = true
panic = "abort"
debug = false

[profile.dist]
inherits = "release"
lto = "fat"

# ── cargo-dist release matrix (X3 #299) ──────────────────────────
#
# Five target triples — cli-tooling role "at least Linux x86_64 +
# one cross target" is met five times over. arm64 linux requires
# cross or a dedicated runner; cargo-dist handles that plumbing.
#
# `cargo dist plan` validates this block offline; CargoDistAdapter
# invokes `cargo dist build` for release archives.

[workspace.metadata.dist]
cargo-dist-version = "0.20.0"
ci = ["github"]
installers = ["shell", "powershell"]
targets = [
    "x86_64-unknown-linux-gnu",
    "aarch64-unknown-linux-gnu",
    "x86_64-pc-windows-msvc",
    "aarch64-apple-darwin",
    "x86_64-apple-darwin",
]
pr-run-mode = "plan"
install-path = "~/.{{ bin_name }}/bin"

[workspace.metadata.dist.dependencies.apt]
# Minimal Linux runtime deps — static-ish builds; openssl via vendored
# feature avoids system-libssl coupling.

# Disable the dist profile's default install-upgraders blurb — the
# scaffold ships a minimal README install section instead.
