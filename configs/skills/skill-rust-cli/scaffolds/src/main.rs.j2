//
// Entry point — wires clap parsing -> logging init -> tokio runtime
// -> subcommand dispatch. Honours the cli-tooling role exit-code
// contract:
//   * 0   success
//   * 1   generic error (anyhow bubble)
//   * 2   usage error (clap parse failure — handled by clap itself)
//   * 130 SIGINT (tokio ctrl-c handler; graceful shutdown)
//
// Logs → stderr (tracing-subscriber); command output → stdout.
// Never print logs on stdout (breaks `{{ bin_name }} ... | jq`).

mod cli;
mod commands;
mod error;
mod logging;

use clap::Parser;
use cli::{Cli, Commands};
use std::process::ExitCode;

{%- if runtime == "tokio" %}

#[tokio::main(flavor = "multi_thread")]
async fn main() -> ExitCode {
    // clap's derive consumes argv and exits with code 2 on parse
    // errors before we ever hit this body. If we're past parse(),
    // we own exit codes 0 / 1 / 130.
    let cli = Cli::parse();

    if let Err(e) = logging::init(cli.verbosity(), cli.json, cli.quiet) {
        eprintln!("failed to init logging: {e:#}");
        return ExitCode::from(1);
    }

    let shutdown = tokio::signal::ctrl_c();
    tokio::select! {
        biased;
        _ = shutdown => {
            tracing::warn!("received SIGINT — shutting down");
            ExitCode::from(130)
        }
        res = dispatch(cli) => match res {
            Ok(()) => ExitCode::from(0),
            Err(e) => {
                tracing::error!(error = ?e, "command failed");
                ExitCode::from(1)
            }
        }
    }
}

async fn dispatch(cli: Cli) -> anyhow::Result<()> {
    match cli.command {
        Commands::Init(args) => commands::init::run(args, cli.json).await,
        Commands::Run(args) => commands::run::run(args, cli.json).await,
        Commands::Status(args) => commands::status::run(args, cli.json).await,
        Commands::Version => commands::version::run(cli.json),
        Commands::Completions(args) => commands::completions::run(args),
    }
}
