fn main() -> ExitCode {
    let cli = Cli::parse();
    if let Err(e) = logging::init(cli.verbosity(), cli.json, cli.quiet) {
        eprintln!("failed to init logging: {e:#}");
        return ExitCode::from(1);
    }
    match dispatch(cli) {
        Ok(()) => ExitCode::from(0),
        Err(e) => {
            tracing::error!(error = ?e, "command failed");
            ExitCode::from(1)
        }
    }
}

fn dispatch(cli: Cli) -> anyhow::Result<()> {
    match cli.command {
        Commands::Init(args) => commands::init::run_sync(args, cli.json),
        Commands::Run(args) => commands::run::run_sync(args, cli.json),
        Commands::Status(args) => commands::status::run_sync(args, cli.json),
        Commands::Version => commands::version::run(cli.json),
        Commands::Completions(args) => commands::completions::run(args),
    }
}
