use anyhow::Result;
use clap::Parser;
use serde::Serialize;

#[derive(Debug, Parser)]
pub struct Args {
    /// Include environment detail (hostname + workdir).
    #[arg(long)]
    pub verbose: bool,
}

#[derive(Debug, Serialize)]
struct Report<'a> {
    status: &'static str,
    name: &'a str,
    version: &'a str,
    build_sha: &'a str,
    workdir: Option<String>,
    platform: &'a str,
}

{%- if runtime == "tokio" %}
pub async fn run(args: Args, json: bool) -> Result<()> {
    emit(&args, json);
    Ok(())
}
{%- else %}
pub fn run_sync(args: Args, json: bool) -> Result<()> {
    emit(&args, json);
    Ok(())
}
{%- endif %}

fn emit(args: &Args, json: bool) {
    let workdir = if args.verbose {
        std::env::current_dir()
            .ok()
            .map(|p| p.display().to_string())
    } else {
        None
    };

    let report = Report {
        status: "ok",
        name: env!("CARGO_PKG_NAME"),
        version: env!("CARGO_PKG_VERSION"),
        build_sha: env!("BUILD_GIT_SHA"),
        workdir,
        platform: std::env::consts::OS,
    };

    if json {
        let line = serde_json::to_string(&report).expect("serialise Report");
        println!("{line}");
    } else {
        println!("status: {} v{} ({}) on {}", report.name, report.version, report.build_sha, report.platform);
        if let Some(wd) = &report.workdir {
            println!("  workdir: {wd}");
        }
    }
}

