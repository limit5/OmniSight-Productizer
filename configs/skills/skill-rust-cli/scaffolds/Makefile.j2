.PHONY: help fmt clippy test cov build run release dist-plan dist-build audit deny clean completions-install

help:
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "\033[36m%-22s\033[0m %s\n", $$1, $$2}'

fmt:  ## cargo fmt --check
	cargo fmt --all -- --check

clippy:  ## cargo clippy -D warnings (role-mandatory)
	cargo clippy --all-targets --all-features -- -D warnings

test:  ## cargo test + llvm-cov 75% floor (X1 Rust gate)
	./scripts/check_cov.sh

build:  ## cargo build --release
	cargo build --release

run:  ## run the CLI binary directly
	cargo run --

release:  ## local release build (alias for build)
	cargo build --release

dist-plan:  ## cargo dist plan (offline validation — X3 CargoDistAdapter hook)
	cargo dist plan

dist-build:  ## cargo dist build --artifacts=all (produces the release archive set)
	cargo dist build --artifacts=all

audit:  ## cargo audit (RustSec DB, X4 CVE gate local hook)
	cargo audit

deny:  ## cargo deny check (licenses + bans + sources + advisories)
	cargo deny check

completions-install:  ## print the bash completion script to stdout (pipe to your shell config)
	cargo run -- completions bash

clean:
	cargo clean
	rm -rf dist/ target/llvm-cov-target
