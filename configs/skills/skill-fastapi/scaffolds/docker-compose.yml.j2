# Generated by SKILL-FASTAPI (X5 #301) — local dev compose.
#
# Brings up the service + DB for `docker compose up -d`. The image
# tag intentionally mirrors the X3 DockerImageAdapter default
# (`{{ project_name }}:0.1.0`) so the same image can be pushed to
# a registry later without a second build.

services:
  api:
    build: .
    image: {{ project_name }}:0.1.0
    container_name: {{ project_name }}-api
    environment:
      APP_ENV: "dev"
{%- if database == "postgres" %}
      DATABASE_URL: "postgresql+asyncpg://{{ package_name }}:{{ package_name }}@db:5432/{{ package_name }}"
{%- else %}
      DATABASE_URL: "sqlite+aiosqlite:///./data/app.db"
{%- endif %}
{%- if auth == "jwt" %}
      JWT_SECRET: "dev-secret-change-me"
{%- endif %}
    ports:
      - "8000:8000"
{%- if database == "postgres" %}
    depends_on:
      db:
        condition: service_healthy
{%- endif %}
    restart: unless-stopped

{%- if database == "postgres" %}

  db:
    image: postgres:16-alpine
    container_name: {{ project_name }}-db
    environment:
      POSTGRES_USER: "{{ package_name }}"
      POSTGRES_PASSWORD: "{{ package_name }}"
      POSTGRES_DB: "{{ package_name }}"
    volumes:
      - db-data:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ package_name }}"]
      interval: 5s
      timeout: 3s
      retries: 10

volumes:
  db-data:
{%- endif %}
