#!/usr/bin/env python3
"""N3-compatible OpenAPI dump.

Generated by SKILL-FASTAPI (X5 #301). The contract matches OmniSight's
own `scripts/dump_openapi.py`:

  * Calls `create_app().openapi()` directly — NO uvicorn boot, no DB,
    no network. Safe to run in CI before deps like postgres are up.
  * Default write path is `./openapi.json` at the project root.
  * `--check` mode writes to a scratch location and diffs against the
    committed file. Exit 1 on drift → CI fails the PR, API-breaking
    changes are caught before merge.

Wire into CI:

    - name: openapi-contract
      run: python scripts/dump_openapi.py --check
"""
from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

_REPO_ROOT = Path(__file__).resolve().parent.parent
_SRC = _REPO_ROOT / "src"
if str(_SRC) not in sys.path:
    sys.path.insert(0, str(_SRC))


def _load_schema() -> dict:
    from {{ package_name }}.main import create_app  # noqa: E402

    app = create_app()
    return app.openapi()


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--out", type=Path, default=_REPO_ROOT / "openapi.json")
    parser.add_argument(
        "--check",
        action="store_true",
        help="exit 1 if the on-disk snapshot differs from the generated schema",
    )
    args = parser.parse_args(argv)

    schema = _load_schema()
    rendered = json.dumps(schema, indent=2, sort_keys=True) + "\n"

    if args.check:
        if not args.out.exists():
            print(f"[openapi] snapshot missing: {args.out}", file=sys.stderr)
            return 1
        on_disk = args.out.read_text(encoding="utf-8")
        if on_disk != rendered:
            print(
                f"[openapi] drift detected against {args.out} — "
                "run `python scripts/dump_openapi.py` and commit the result",
                file=sys.stderr,
            )
            return 1
        print(f"[openapi] snapshot matches ({args.out})")
        return 0

    args.out.write_text(rendered, encoding="utf-8")
    print(f"[openapi] wrote {args.out} ({len(rendered)} bytes)")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
