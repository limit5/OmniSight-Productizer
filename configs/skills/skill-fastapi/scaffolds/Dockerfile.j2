# Generated by SKILL-FASTAPI (X5 #301).
#
# Multi-stage build:
#   * Stage 1 (builder) uses `uv` for fast dependency resolution — the
#     backend-python role's default package manager (X2 #298). Falls
#     back to pip if uv is unavailable at build time.
#   * Stage 2 (runtime) is python:3.12-slim — no build tools, no
#     compilers. X4 CVE-scan ({backend.software_compliance.cves}) treats
#     anything outside runtime deps as a finding.
#
# Wired to backend.build_adapters.DockerImageAdapter (X3 #299). Build
# via `build_artifact(target="docker", app_path=".", ...)` or by hand:
#   docker build -t {{ project_name }}:0.1.0 .

ARG PYTHON_VERSION=3.12

# ── Stage 1: builder ─────────────────────────────────────────────
FROM python:${PYTHON_VERSION}-slim AS builder

ENV PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    UV_SYSTEM_PYTHON=1

WORKDIR /build

# uv if available; otherwise pip. The uv binary ships as a single
# static blob so fallback is cheap.
RUN pip install --no-cache-dir "uv>=0.2" || true

COPY pyproject.toml ./
COPY src ./src

RUN if command -v uv >/dev/null 2>&1; then \
        uv pip install --system --no-cache-dir . ; \
    else \
        pip install --no-cache-dir . ; \
    fi

# ── Stage 2: runtime ─────────────────────────────────────────────
FROM python:${PYTHON_VERSION}-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Non-root runtime user — defence-in-depth; mandatory for the Helm
# chart's securityContext (deploy/helm/templates/deployment.yaml).
RUN groupadd --system app && useradd --system --gid app --uid 10001 app

WORKDIR /app

COPY --from=builder /usr/local/lib/python*/site-packages /usr/local/lib/python3.12/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin
COPY src ./src
COPY alembic.ini ./
COPY alembic ./alembic

USER app
EXPOSE 8000

# Container-native healthcheck — same endpoint the k8s liveness probe
# hits. If the app deadlocks during lifespan, this goes red.
HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/api/v1/health', timeout=2).read()" || exit 1

CMD ["uvicorn", "{{ package_name }}.main:app", "--host", "0.0.0.0", "--port", "8000"]
