"""FastAPI app factory.

Generated by SKILL-FASTAPI (X5 #301).

The app factory pattern (vs. module-level `app = FastAPI()`) matters
for two reasons:
  1. pytest can construct a fresh app per-test with overridden config
     (see tests/conftest.py).
  2. `scripts/dump_openapi.py` can call `create_app().openapi()`
     offline without triggering the lifespan (DB connect / network) —
     same contract as OmniSight's N3 governance.
"""

from __future__ import annotations

import logging
from contextlib import asynccontextmanager
from typing import AsyncIterator

from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware

from {{ package_name }}.api.v1 import router as v1_router
from {{ package_name }}.config import get_settings
from {{ package_name }}.core.logging import configure_logging
from {{ package_name }}.db import dispose_engine, init_engine

logger = logging.getLogger(__name__)


@asynccontextmanager
async def lifespan(app: FastAPI) -> AsyncIterator[None]:
    settings = get_settings()
    configure_logging(settings.log_level)
    init_engine(settings.database_url)
    logger.info("{{ project_name }} starting (env=%s)", settings.app_env)
    try:
        yield
    finally:
        await dispose_engine()
        logger.info("{{ project_name }} stopped")


def create_app() -> FastAPI:
    settings = get_settings()
    app = FastAPI(
        title="{{ project_name }}",
        version="0.1.0",
        description="Generated by SKILL-FASTAPI (X5 #301).",
        lifespan=lifespan,
        openapi_url="/openapi.json",
        docs_url="/docs",
        redoc_url="/redoc",
    )
    app.add_middleware(
        CORSMiddleware,
        allow_origins=settings.cors_origins,
        allow_credentials=True,
        allow_methods=["*"],
        allow_headers=["*"],
    )
    app.include_router(v1_router, prefix="/api/v1")
    return app


app = create_app()
