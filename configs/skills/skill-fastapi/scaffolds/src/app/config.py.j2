"""Pydantic-settings configuration.

Generated by SKILL-FASTAPI (X5 #301).

Never read `os.environ` directly — the backend-python role skill
flags that as an anti-pattern because it defeats static analysis and
makes test-time config overrides harder.
"""

from __future__ import annotations

from functools import lru_cache

from pydantic import Field
from pydantic_settings import BaseSettings, SettingsConfigDict


class Settings(BaseSettings):
    model_config = SettingsConfigDict(
        env_file=".env",
        env_file_encoding="utf-8",
        case_sensitive=False,
        extra="ignore",
    )

    app_env: str = Field(default="dev", description="dev | staging | prod")
    log_level: str = Field(default="INFO")
    cors_origins: list[str] = Field(default_factory=lambda: ["*"])

{%- if database == "postgres" %}
    database_url: str = Field(
        default="postgresql+asyncpg://{{ package_name }}:{{ package_name }}@localhost:5432/{{ package_name }}",
        description="SQLAlchemy async DSN",
    )
{%- else %}
    database_url: str = Field(
        default="sqlite+aiosqlite:///./data/app.db",
        description="SQLAlchemy async DSN",
    )
{%- endif %}
{%- if auth == "jwt" %}

    jwt_secret: str = Field(default="change-me-change-me-change-me-32c")
    jwt_algorithm: str = Field(default="HS256")
    jwt_expire_minutes: int = Field(default=60)
{%- elif auth == "oauth2" %}

    oauth2_client_id: str = Field(default="")
    oauth2_client_secret: str = Field(default="")
    oauth2_authorize_url: str = Field(default="")
    oauth2_token_url: str = Field(default="")
{%- endif %}


@lru_cache
def get_settings() -> Settings:
    return Settings()
