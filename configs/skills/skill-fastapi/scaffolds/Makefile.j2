# Generated by SKILL-FASTAPI (X5 #301).
# `make help` lists every target.

.PHONY: help install run test cov lint type migrate openapi docker helm clean

help:
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "\033[36m%-20s\033[0m %s\n", $$1, $$2}'

install:  ## uv sync (fallback: pip install -e .[dev])
	@if command -v uv >/dev/null 2>&1; then uv sync; else pip install -e .[dev]; fi

run:  ## uvicorn dev server with reload
	uvicorn {{ package_name }}.main:app --reload

test:  ## pytest + coverage (X1 simulate gate)
	pytest

cov:  ## pytest with HTML coverage report
	pytest --cov-report=html

lint:  ## ruff check + format
	ruff check .
	ruff format --check .

type:  ## mypy --strict
	mypy src/

migrate:  ## alembic upgrade head
	alembic upgrade head

openapi:  ## dump openapi.json (N3 governance)
	python scripts/dump_openapi.py

docker:  ## docker build
	docker build -t {{ project_name }}:0.1.0 .

helm:  ## helm lint + package
	helm lint deploy/helm
	helm package deploy/helm -d dist/

clean:
	rm -rf .pytest_cache .mypy_cache .ruff_cache htmlcov coverage.xml .coverage dist/ build/ *.egg-info
