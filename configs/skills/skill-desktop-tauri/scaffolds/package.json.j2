{
  "$comment": "Generated by SKILL-DESKTOP-TAURI (X8 #304). Frontend deps only — Rust crates live in src-tauri/Cargo.toml.",
  "name": "{{ slug_name }}",
  "version": "0.1.0",
  "private": true,
  "description": "{{ project_name }} — Tauri 2.x desktop app scaffolded by SKILL-DESKTOP-TAURI",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "{% if frontend == 'react' %}tsc --noEmit && vite build{% else %}vue-tsc --noEmit && vite build{% endif %}",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
{%- if frontend == "react" %}
    "@tauri-apps/api": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
{%- else %}
    "@tauri-apps/api": "^2.1.1",
    "vue": "^3.5.13"
{%- endif %}
{%- if updater %},
    "@tauri-apps/plugin-updater": "^2.0.1",
    "@tauri-apps/plugin-process": "^2.2.1"
{%- endif %}
  },
  "devDependencies": {
{%- if frontend == "react" %}
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.3",
{%- else %}
    "@vitejs/plugin-vue": "^5.2.1",
    "vue-tsc": "^2.1.10",
    "@vue/test-utils": "^2.4.6",
{%- endif %}
    "@tauri-apps/cli": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
