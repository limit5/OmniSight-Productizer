// Generated by SKILL-DESKTOP-TAURI (X8 #304).
// Vitest + @vue/test-utils smoke — verifies the Vue 3 surface
// renders, the input accepts text, and the IPC error envelope
// surfaces in the alert region. The Rust IPC is mocked at the
// `@tauri-apps/api/core` boundary so this test runs in jsdom
// without the native runtime.

import { describe, it, expect, vi, beforeEach } from "vitest";
import { mount, flushPromises } from "@vue/test-utils";

vi.mock("@tauri-apps/api/core", () => ({
  invoke: vi.fn(async (name: string, args?: { name?: string }) => {
    if (name !== "greet") throw { kind: "unknown", message: "no" };
    if (!args?.name?.trim()) {
      throw { kind: "invalid_argument", message: "name must not be empty" };
    }
    return `Hello, ${args.name}! Welcome to {{ app_name }}.`;
  }),
}));

import App from "../App.vue";

describe("<App />", () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  it("renders the title", () => {
    const wrapper = mount(App);
    expect(wrapper.text()).toContain("{{ app_name }}");
  });

  it("greets a typed name", async () => {
    const wrapper = mount(App);
    await wrapper.find("input").setValue("Tauri");
    await wrapper.find("button").trigger("click");
    await flushPromises();
    expect(wrapper.text()).toContain("Hello, Tauri");
  });

  it("surfaces IPC errors via the alert region", async () => {
    const wrapper = mount(App);
    await wrapper.find("button").trigger("click");
    await flushPromises();
    const alert = wrapper.find('[role="alert"]');
    expect(alert.exists()).toBe(true);
    expect(alert.text()).toContain("invalid_argument");
  });
});
