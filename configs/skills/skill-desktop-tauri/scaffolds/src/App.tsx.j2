// Operators rip this out and replace with real screens; the IPC + error
// envelope plumbing in `useTauri.ts` is what's worth keeping.

import { useState } from "react";
import { greet, type CommandError } from "./useTauri";

export default function App() {
  const [name, setName] = useState("");
  const [message, setMessage] = useState("");
  const [error, setError] = useState<CommandError | null>(null);

  const onGreet = async () => {
    setError(null);
    try {
      const reply = await greet(name);
      setMessage(reply);
    } catch (e) {
      setError(e as CommandError);
      setMessage("");
    }
  };

  return (
    <main className="app">
      <h1>{{ app_name }}</h1>
      <p>Tauri 2.x + React — scaffolded by SKILL-DESKTOP-TAURI (X8 #304).</p>
      <input
        aria-label="name"
        placeholder="your name"
        value={name}
        onChange={(e) => setName(e.target.value)}
      />
      <button onClick={onGreet}>Greet</button>
      {message && <p className="greeting">{message}</p>}
      {error && (
        <p role="alert" style={% raw %}{{ color: "#dc2626" }}{% endraw %}>
          {error.kind}: {error.message}
        </p>
      )}
    </main>
  );
}
