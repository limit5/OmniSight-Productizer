<!--
  Generated by SKILL-DESKTOP-TAURI (X8 #304).
  Minimal Vue 3 surface — exercises the `greet` IPC command end-to-end.
  Operators replace this with real screens; the IPC + error-envelope
  plumbing in `useTauri.ts` is what's worth keeping.
-->
<script setup lang="ts">
import { ref } from "vue";
import { greet, type CommandError } from "./useTauri";

const name = ref("");
const message = ref("");
const error = ref<CommandError | null>(null);

async function onGreet() {
  error.value = null;
  try {
    message.value = await greet(name.value);
  } catch (e) {
    error.value = e as CommandError;
    message.value = "";
  }
}
</script>

<template>
  <main class="app">
    <h1>{{ app_name }}</h1>
    <p>Tauri 2.x + Vue — scaffolded by SKILL-DESKTOP-TAURI (X8 #304).</p>
    <input aria-label="name" placeholder="your name" v-model="name" />
    <button @click="onGreet">Greet</button>
    <p v-if="message" class="greeting">{{ "{{ message }}" }}</p>
    <p v-if="error" role="alert" :style="{ color: '#dc2626' }">
      {{ "{{ error.kind }}" }}: {{ "{{ error.message }}" }}
    </p>
  </main>
</template>
