# Generated by SKILL-DESKTOP-TAURI (X8 #304).
#
# tauri-action-driven release matrix across the three desktop OSes.
# Triggered on tag push (`app-v*`); produces a draft GitHub Release
# with the full installer set and (when updater=on) the signed
# `latest.json` manifest the auto-update channel reads.
#
# Operator-required CI secrets (when updater=on):
#   TAURI_SIGNING_PRIVATE_KEY            — minisign private key body
#   TAURI_SIGNING_PRIVATE_KEY_PASSWORD   — passphrase for the key

name: release

on:
  push:
    tags:
      - "app-v*"
  workflow_dispatch:

jobs:
  build:
    name: build ({% raw %}${{ matrix.platform }}{% endraw %})
    permissions:
      contents: write
    strategy:
      fail-fast: false
      matrix:
        include:
          - platform: macos-14          # macOS arm64 (Apple silicon)
            arch: aarch64
          - platform: ubuntu-22.04      # Linux x86_64
            arch: x86_64
          - platform: windows-latest    # Windows x86_64
            arch: x86_64
    runs-on: {% raw %}${{ matrix.platform }}{% endraw %}
    steps:
      - uses: actions/checkout@v4

      - name: install pnpm
        uses: pnpm/action-setup@v4
        with:
          version: 9

      - name: setup node
        uses: actions/setup-node@v4
        with:
          node-version: 20
          cache: pnpm

      - name: setup rust
        uses: dtolnay/rust-toolchain@stable
        with:
          targets: {% raw %}${{ matrix.platform == 'macos-14' && 'aarch64-apple-darwin' || '' }}{% endraw %}

      - name: install linux deps
        if: matrix.platform == 'ubuntu-22.04'
        run: |
          sudo apt-get update
          sudo apt-get install -y \
            libwebkit2gtk-4.1-dev \
            libappindicator3-dev \
            librsvg2-dev \
            patchelf \
            build-essential \
            libssl-dev

      - name: install frontend deps
        run: pnpm install --frozen-lockfile

      - name: build + bundle
        uses: tauri-apps/tauri-action@v0
{%- if updater %}
        env:
          TAURI_SIGNING_PRIVATE_KEY: {% raw %}${{ secrets.TAURI_SIGNING_PRIVATE_KEY }}{% endraw %}
          TAURI_SIGNING_PRIVATE_KEY_PASSWORD: {% raw %}${{ secrets.TAURI_SIGNING_PRIVATE_KEY_PASSWORD }}{% endraw %}
{%- endif %}
        with:
          tagName: app-v__VERSION__
          releaseName: "v__VERSION__"
          releaseBody: "See CHANGELOG.md for details."
          releaseDraft: true
          prerelease: false
          args: {% raw %}${{ matrix.platform == 'macos-14' && '--target aarch64-apple-darwin' || '' }}{% endraw %}
