{
  "$comment": "Generated by SKILL-DESKTOP-TAURI (X8 #304). Tauri 2.x bundle config — strict CSP, reverse-DNS identifier, three-OS bundle targets, minisign-signed updater envelope.",
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "{{ app_name }}",
  "version": "0.1.0",
  "identifier": "{{ identifier }}",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: tauri:; connect-src 'self' ipc: http://ipc.localhost"
    },
    "windows": [
      {
        "label": "main",
        "title": "{{ app_name }}",
        "width": 1024,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "deb", "rpm", "appimage", "dmg", "app"],
    "category": "Productivity",
    "shortDescription": "{{ app_name }}",
    "longDescription": "{{ app_name }} — Tauri 2.x desktop app scaffolded by SKILL-DESKTOP-TAURI (X8 #304).",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "windows": {
      "wix": {
        "language": ["en-US"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "linux": {
      "deb": { "depends": [] },
      "appimage": { "bundleMediaFramework": false }
    }{% if updater %},
    "createUpdaterArtifacts": true{% endif %}
  }{% if updater %},
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://releases.example.com/{% raw %}{{target}}/{{current_version}}{% endraw %}"
      ],
      "dialog": false,
      "pubkey": "REPLACE_WITH_MINISIGN_PUBLIC_KEY"
    }
  }{% endif %}
}
