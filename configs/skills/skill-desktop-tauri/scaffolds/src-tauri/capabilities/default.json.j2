{
  "$comment": "Generated by SKILL-DESKTOP-TAURI (X8 #304). Tauri 2 Capability System — default-deny. Each #[tauri::command] is granted explicitly; the desktop-tauri role's mandatory anti-pattern (`permissions: ['**']`) is rejected here on purpose.",
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for {{ app_name }}.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:app:default",
    "core:event:default",
    "core:path:default",
    "dialog:allow-message",
    "dialog:allow-ask",
    "shell:allow-open",
{%- if updater %}
    "updater:default",
    "process:allow-restart",
{%- endif %}
    "{{ crate_name }}:allow-greet",
    "{{ crate_name }}:allow-app-info"
  ]
}
