// Generated by SKILL-DESKTOP-TAURI (X8 #304).
//
// IPC handlers — every public function carries `#[tauri::command]`
// so the Tauri 2.x capability system can grant access by name.
// The desktop-tauri role's mandatory anti-pattern — exposing raw
// shell / fs without scoping — is rejected here on purpose: every
// handler takes typed args, returns a Result with a stable error
// shape, and never spawns shells.

use serde::{Deserialize, Serialize};

/// Stable error envelope returned to the frontend.
///
/// The frontend's `useTauri.ts` hook converts a rejected promise
/// back into this shape, so every component handles errors via
/// `{ kind, message }` rather than raw strings.
#[derive(Debug, Serialize, Deserialize)]
pub struct CommandError {
    pub kind: String,
    pub message: String,
}

impl CommandError {
    pub fn new(kind: &str, message: impl Into<String>) -> Self {
        Self {
            kind: kind.to_string(),
            message: message.into(),
        }
    }
}

#[derive(Debug, Serialize)]
pub struct AppInfo {
    pub name: String,
    pub version: String,
    pub identifier: String,
}

/// Canonical greeting handler — the single example IPC call the
/// frontend invokes during the boot smoke-test.
#[tauri::command]
pub fn greet(name: &str) -> Result<String, CommandError> {
    let trimmed = name.trim();
    if trimmed.is_empty() {
        return Err(CommandError::new("invalid_argument", "name must not be empty"));
    }
    Ok(format!("Hello, {trimmed}! Welcome to {{ app_name }}."))
}

/// Returns metadata about the running app — the frontend uses this
/// to render the about dialog without hard-coding strings on its
/// side. Sourced from Cargo env vars baked in at compile time.
#[tauri::command]
pub fn app_info() -> AppInfo {
    AppInfo {
        name: env!("CARGO_PKG_NAME").to_string(),
        version: env!("CARGO_PKG_VERSION").to_string(),
        identifier: "{{ identifier }}".to_string(),
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn greet_rejects_empty_name() {
        let err = greet("").unwrap_err();
        assert_eq!(err.kind, "invalid_argument");
    }

    #[test]
    fn greet_rejects_whitespace_only() {
        assert!(greet("   ").is_err());
    }

    #[test]
    fn greet_returns_message() {
        let msg = greet("Tauri").unwrap();
        assert!(msg.contains("Tauri"));
        assert!(msg.contains("{{ app_name }}"));
    }

    #[test]
    fn app_info_has_identifier() {
        let info = app_info();
        assert_eq!(info.identifier, "{{ identifier }}");
        assert!(!info.version.is_empty());
    }
}
