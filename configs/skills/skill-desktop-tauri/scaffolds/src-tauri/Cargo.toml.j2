# Generated by SKILL-DESKTOP-TAURI (X8 #304).
#
# Tauri 2.x desktop binary crate. Aligns with the desktop-tauri /
# backend-rust role defaults:
#   * tauri 2.x — system webview, capability system
#   * tracing + tracing-subscriber for structured logs (stderr only)
#   * thiserror + anyhow bridge for #[tauri::command] error mapping
#   * release profile tuned for installer size (lto=fat, strip=true)
#   * [workspace.metadata.dist] block consumed by cargo-dist (X3 #299)

[package]
name = "{{ crate_name }}"
version = "0.1.0"
edition = "2021"
rust-version = "1.76"
description = "{{ app_name }} — Tauri 2.x desktop app scaffolded by SKILL-DESKTOP-TAURI"
license = "Apache-2.0"
readme = "../README.md"
publish = false

[lib]
name = "{{ crate_name }}_lib"
crate-type = ["staticlib", "cdylib", "rlib"]

[[bin]]
name = "{{ bin_name }}"
path = "src/main.rs"

[build-dependencies]
tauri-build = { version = "2.0.4", features = [] }

[dependencies]
tauri = { version = "2.1.1", features = [] }
tauri-plugin-shell = "2.0.2"
tauri-plugin-dialog = "2.0.4"
{%- if updater %}
tauri-plugin-updater = "2.0.2"
tauri-plugin-process = "2.2.0"
{%- endif %}
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
anyhow = "1.0"
thiserror = "1.0"
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter", "fmt"] }

[dev-dependencies]
tempfile = "3.10"

[profile.release]
opt-level = 3
lto = "fat"
codegen-units = 1
strip = true
panic = "abort"
debug = false

[profile.dist]
inherits = "release"
lto = "fat"

# ── cargo-dist release matrix (X3 #299) ──────────────────────────
#
# 5 target triples — Linux x86_64/arm64 (gnu), Windows MSVC, macOS
# arm64/x86_64. The real release runs through `tauri build` per-OS
# via `.github/workflows/release.yml` (tauri-action), but cargo-dist
# is wired here so the X3 CargoDistAdapter has a config to validate
# offline. `cargo dist plan` exits zero on this block.

[workspace.metadata.dist]
cargo-dist-version = "0.20.0"
ci = ["github"]
installers = ["shell", "powershell"]
targets = [
    "x86_64-unknown-linux-gnu",
    "aarch64-unknown-linux-gnu",
    "x86_64-pc-windows-msvc",
    "aarch64-apple-darwin",
    "x86_64-apple-darwin",
]
pr-run-mode = "plan"
install-path = "~/.{{ bin_name }}/bin"
