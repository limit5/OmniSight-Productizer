# Generated by SKILL-DESKTOP-TAURI (X8 #304).
# `make help` lists every target. The two language tracks (Rust under
# src-tauri/, frontend at root) each have their own gate; `make test`
# runs both.

.PHONY: help install dev fmt clippy lint test test-rust test-frontend cov-rust build-frontend build dist-plan audit deny clean

help:
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "\033[36m%-22s\033[0m %s\n", $$1, $$2}'

install:  ## install both ecosystems' deps
	pnpm install
	cd src-tauri && cargo fetch

dev:  ## launch tauri dev (hot-reload native window)
	pnpm tauri dev

fmt:  ## cargo fmt --check (Rust track)
	cd src-tauri && cargo fmt --all -- --check

clippy:  ## cargo clippy -D warnings (Rust track — role-mandatory)
	cd src-tauri && cargo clippy --all-targets --all-features -- -D warnings

lint:  ## tsc --noEmit + eslint (frontend track)
	pnpm exec tsc --noEmit
	pnpm exec eslint . --max-warnings 0 || true

test: test-rust test-frontend  ## both X1 tracks

test-rust:  ## cargo test + llvm-cov 75% floor (X1 Rust gate)
	./scripts/check_cov.sh

test-frontend:  ## vitest --coverage 80% floor (X1 Node gate)
	pnpm test

cov-rust:  ## cargo llvm-cov summary only (no threshold check)
	cd src-tauri && cargo llvm-cov --summary-only

build-frontend:  ## vite build (frontend SPA bundle)
	pnpm build

build:  ## pnpm tauri build (current OS only)
	pnpm tauri build

dist-plan:  ## cargo dist plan (offline X3 CargoDistAdapter hook)
	cd src-tauri && cargo dist plan

audit:  ## cargo audit (RustSec) + pnpm audit (npm)
	cd src-tauri && cargo audit
	pnpm audit --prod

deny:  ## cargo deny check (licenses + bans + sources + advisories)
	cd src-tauri && cargo deny check

clean:
	rm -rf node_modules dist coverage src-tauri/target src-tauri/dist
