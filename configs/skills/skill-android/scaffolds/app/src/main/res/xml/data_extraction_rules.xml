<?xml version="1.0" encoding="utf-8"?>
<!--
  SKILL-ANDROID (P8 #293) — data extraction rules (Android 12+).
  Controls what data D2D transfer + cloud backup copy. Matches the
  Android 12 "Data Safety" policy tighter scope requirement.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="auth.xml" />
        <exclude domain="sharedpref" path="secrets.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="auth.xml" />
        <exclude domain="sharedpref" path="secrets.xml" />
    </device-transfer>
</data-extraction-rules>
