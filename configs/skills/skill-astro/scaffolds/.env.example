# Generated by SKILL-ASTRO (W8 #282).
# Copy to `.env` and fill in real values before running.

# Site URL (required for sitemap + RSS absolute URLs)
SITE_URL=http://localhost:4321

# Target override (optional — scaffolder picks a default)
# ASTRO_TARGET=static | node | vercel | cloudflare
# ASTRO_TARGET=static

# Sanity CMS (only when cms=sanity)
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-10-01
SANITY_PREVIEW_TOKEN=
SANITY_WEBHOOK_SECRET=

# Contentful CMS (only when cms=contentful)
CONTENTFUL_SPACE_ID=
CONTENTFUL_ENVIRONMENT=master
CONTENTFUL_DELIVERY_TOKEN=
CONTENTFUL_PREVIEW_TOKEN=
CONTENTFUL_WEBHOOK_SECRET=

