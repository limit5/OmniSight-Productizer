// CRITICAL: the `output` + `adapter` pair is resolved from the
// ASTRO_TARGET env var with a scaffold-time default of
// `{{ default_target }}`. This lets the same source tree ship to all
// four W8 Astro targets (static / @astrojs/node / @astrojs/vercel /
// @astrojs/cloudflare) without branching on a build-time flag. Do
// NOT hard-code output/adapter — the whole point of the W4
// multi-adapter wiring is that `ASTRO_TARGET` is the single lever.

import { defineConfig } from "astro/config"
import mdx from "@astrojs/mdx"
import sitemap from "@astrojs/sitemap"
{%- if islands == "react" %}
import react from "@astrojs/react"
{%- endif %}
{%- if islands == "vue" %}
import vue from "@astrojs/vue"
{%- endif %}
{%- if islands == "svelte" %}
import svelte from "@astrojs/svelte"
{%- endif %}
{%- if target in ["node", "all"] %}
import nodeAdapter from "@astrojs/node"
{%- endif %}
{%- if target in ["vercel", "all"] %}
import vercelAdapter from "@astrojs/vercel"
{%- endif %}
{%- if target in ["cloudflare", "all"] %}
import cloudflareAdapter from "@astrojs/cloudflare"
{%- endif %}

const ASTRO_TARGET = process.env.ASTRO_TARGET || "{{ default_target }}"

function resolveOutputAdapter(target) {
  switch (target) {
{%- if target in ["node", "all"] %}
    case "node":
      return { output: "server", adapter: nodeAdapter({ mode: "standalone" }) }
{%- endif %}
{%- if target in ["vercel", "all"] %}
    case "vercel":
      return { output: "server", adapter: vercelAdapter() }
{%- endif %}
{%- if target in ["cloudflare", "all"] %}
    case "cloudflare":
      return { output: "server", adapter: cloudflareAdapter() }
{%- endif %}
    case "static":
    default:
      return { output: "static" }
  }
}

const { output, adapter } = resolveOutputAdapter(ASTRO_TARGET)

// https://astro.build/config
export default defineConfig({
  site: process.env.SITE_URL || "https://example.com",
  output,
  adapter,

  // Bundle budget — matches the W1 profile's bundle_size_budget.
