---
// Generated by SKILL-ASTRO (W8 #282).
// Base layout — ships semantic landmark header + main + footer so
// the W5 WCAG gate passes without additional markup. Injects Open
// Graph + description + lang="en" for the W3 seo role.
export interface Props {
  title: string
  description?: string
  heroImage?: string
}
const {
  title,
  description = "{{ project_name }} (SKILL-ASTRO W8 #282)",
  heroImage,
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString()
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" type="application/rss+xml" title="{{ project_name }}" href="/rss.xml" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {heroImage && <meta property="og:image" content={heroImage} />}
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header role="banner">
      <nav aria-label="primary">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/blog/hello-world">Blog</a>
      </nav>
    </header>
    <main id="main" role="main">
      <slot />
    </main>
    <footer role="contentinfo">
      <small>Generated by SKILL-ASTRO (W8 #282)</small>
    </footer>
  </body>
</html>

<style is:global>
  html, body {
    margin: 0;
    font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  }
  main {
    max-width: 72ch;
    margin: 0 auto;
    padding: 1.25rem;
  }
  header[role="banner"] nav a {
    margin-right: 1rem;
  }
</style>
