---
// Generated by SKILL-ASTRO (W8 #282).
// Minimal GDPR/ePrivacy cookie-banner — first-party consent manager
// rendered server-side, hydrated lazily by the inline script.
// Recognised by backend.web_compliance.gdpr via the "cookie-banner"
// signature below.
---

<div
  id="consent-banner"
  role="dialog"
  aria-labelledby="consent-heading"
  aria-describedby="consent-desc"
  hidden
>
  <h2 id="consent-heading">Cookie preferences</h2>
  <p id="consent-desc">
    We use strictly necessary cookies by default. Optional analytics
    cookies help us improve the product — your choice.
  </p>
  <button type="button" data-consent="accept">Accept</button>
  <button type="button" data-consent="reject">Reject optional</button>
</div>

<script>
  const banner = document.getElementById("consent-banner")
  if (banner) {
    const COOKIE = "consent_v1"
    const read = () =>
      document.cookie.match(/(?:^|; )consent_v1=([^;]+)/)?.[1] ?? null
    if (read() === null) banner.removeAttribute("hidden")
    for (const btn of banner.querySelectorAll<HTMLButtonElement>("[data-consent]")) {
      btn.addEventListener("click", () => {
        const value = btn.dataset.consent as "accept" | "reject"
        const maxAge = 60 * 60 * 24 * 365
        document.cookie = `${COOKIE}=${value}; Path=/; Max-Age=${maxAge}; SameSite=Lax; Secure`
        banner.setAttribute("hidden", "")
        window.dispatchEvent(new CustomEvent("consent:update", { detail: value }))
      })
    }
  }
</script>
