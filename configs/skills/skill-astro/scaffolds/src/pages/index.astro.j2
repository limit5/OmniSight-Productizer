---
// Generated by SKILL-ASTRO (W8 #282).
// Home page — lists the content-collection entries so editors can
// see their MDX posts show up immediately after a build. The
// collection query runs at build time in SSG mode (the default
// target), and at request time when the operator flips to an SSR
// adapter via ASTRO_TARGET.
import BaseLayout from "../layouts/BaseLayout.astro"
import { getCollection } from "astro:content"

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)
---

<BaseLayout title="{{ project_name }} — Home">
  <section aria-labelledby="home-heading">
    <h1 id="home-heading">{{ project_name }}</h1>
    <p>
      Content-heavy Astro 5 site generated by SKILL-ASTRO (W8 #282).
      See <code>src/content/blog/</code> for the MDX posts below.
    </p>

    <h2 id="posts-heading">Recent posts</h2>
    <ul aria-labelledby="posts-heading">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}`}>
            <strong>{post.data.title}</strong>
          </a>
          <p>{post.data.description}</p>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
