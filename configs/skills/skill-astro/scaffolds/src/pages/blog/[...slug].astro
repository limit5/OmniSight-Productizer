---
// Generated by SKILL-ASTRO (W8 #282).
// Dynamic route for blog content collection. In `output: static`
// this runs at build time and pre-renders every post into static
// HTML; in `output: server` it runs at request time via the chosen
// adapter. The page is identical in both modes — Astro handles the
// dispatch, SKILL-ASTRO doesn't have to.
import { getCollection, type CollectionEntry } from "astro:content"
import BaseLayout from "../../layouts/BaseLayout.astro"

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft)
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }))
}

type Props = { post: CollectionEntry<"blog"> }
const { post } = Astro.props
const { Content } = await post.render()
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  heroImage={post.data.heroImage}
>
  <article aria-labelledby="post-heading">
    <header>
      <h1 id="post-heading">{post.data.title}</h1>
      <p>
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString("en-US")}
        </time>
        {" · "}
        <span>{post.data.author}</span>
      </p>
      {post.data.tags.length > 0 && (
        <ul aria-label="tags">
          {post.data.tags.map((tag) => (
            <li>#{tag}</li>
          ))}
        </ul>
      )}
    </header>
    <Content />
  </article>
</BaseLayout>
