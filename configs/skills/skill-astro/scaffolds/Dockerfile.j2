# Generated by SKILL-ASTRO (W8 #282).
# Multi-stage container. Shape depends on target:
#   * static:   build + copy dist/ into nginx:alpine
#   * node/all: build + run under @astrojs/node standalone entry
# Bound to the W1 `web-static.yaml` or `web-ssr-node.yaml` profile.

# ── build stage ──────────────────────────────────────────────
FROM node:20-alpine AS build
WORKDIR /app
COPY package.json ./
RUN npm install --no-audit --no-fund
COPY . .
ENV ASTRO_TARGET={{ default_target }}
RUN npm run build

{%- if target == "static" %}
# ── runtime stage (static: nginx) ────────────────────────────
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
{%- else %}
# ── runtime stage (node standalone) ──────────────────────────
FROM node:20-alpine
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=4321
ENV HOST=0.0.0.0
COPY --from=build /app/dist ./dist
EXPOSE 4321
USER node
CMD ["node", "./dist/server/entry.mjs"]
{%- endif %}
