# Generated by SKILL-GO-SERVICE (X6 #302) — local dev compose.
#
# Brings up the service{% if database == "postgres" %} + postgres{% endif %} for `docker compose up -d`. Image
# tag mirrors the X3 DockerImageAdapter default
# ({{ project_name }}:0.1.0) so the same image can be pushed later
# without a second build.

services:
  api:
    build: .
    image: {{ project_name }}:0.1.0
    container_name: {{ project_name }}-api
    environment:
      APP_ENV: "dev"
      LOG_LEVEL: "info"
      ADDR: ":8080"
{%- if database == "postgres" %}
      DATABASE_URL: "postgres://{{ project_name }}:{{ project_name }}@db:5432/{{ project_name }}?sslmode=disable"
{%- elif database == "sqlite" %}
      DATABASE_URL: "file:/data/app.db?_pragma=journal_mode(WAL)"
{%- endif %}
    ports:
      - "8080:8080"
{%- if database == "postgres" %}
    depends_on:
      db:
        condition: service_healthy
{%- endif %}
    restart: unless-stopped

{%- if database == "postgres" %}

  db:
    image: postgres:16-alpine
    container_name: {{ project_name }}-db
    environment:
      POSTGRES_USER: "{{ project_name }}"
      POSTGRES_PASSWORD: "{{ project_name }}"
      POSTGRES_DB: "{{ project_name }}"
    volumes:
      - db-data:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ project_name }}"]
      interval: 5s
      timeout: 3s
      retries: 10

volumes:
  db-data:
{%- endif %}
