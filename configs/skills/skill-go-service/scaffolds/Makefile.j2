# Generated by SKILL-GO-SERVICE (X6 #302).
# `make help` lists every target.

.PHONY: help tidy run build test cov lint vet fmt docker helm release-snapshot release-check clean

help:
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "\033[36m%-20s\033[0m %s\n", $$1, $$2}'

tidy:  ## go mod tidy (populate go.sum)
	go mod tidy

run:  ## run the dev server
	go run ./cmd/server

build:  ## build a local binary under bin/
	CGO_ENABLED=0 go build -trimpath -ldflags "-s -w" -o bin/{{ project_name }} ./cmd/server

test:  ## go test -race -cover + X1 70% floor
	./scripts/check_cov.sh

cov:  ## open HTML coverage report
	go test -cover -coverprofile=coverage.out ./...
	go tool cover -html=coverage.out -o coverage.html
	@echo "open coverage.html"

lint:  ## golangci-lint run
	golangci-lint run

vet:  ## go vet ./...
	go vet ./...

fmt:  ## gofmt -s -w . + goimports
	gofmt -s -w .
	@command -v goimports >/dev/null 2>&1 && goimports -w . || true

docker:  ## docker build
	docker build -t {{ project_name }}:0.1.0 .

helm:  ## helm lint + package
	helm lint deploy/helm
	helm package deploy/helm -d dist/

release-snapshot:  ## goreleaser release --snapshot --clean
	goreleaser release --snapshot --clean

release-check:  ## goreleaser check (offline config validation)
	goreleaser check

clean:
	rm -rf bin/ dist/ coverage.out coverage.html
