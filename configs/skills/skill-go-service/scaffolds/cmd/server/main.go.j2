// Generated by SKILL-GO-SERVICE (X6 #302).
//
// Entry point — wires config -> logging -> db -> router, then runs
// the HTTP server with graceful shutdown on SIGINT/SIGTERM. Matches
// the backend-go role skill's "no panic in library code, context-aware
// shutdown" rules (configs/roles/software/backend-go.skill.md).

package main

import (
	"context"
	"errors"
	"log/slog"
	"net/http"
	"os"
	"os/signal"
	"syscall"
	"time"

	"{{ module_path }}/internal/api"
	"{{ module_path }}/internal/config"
	"{{ module_path }}/internal/db"
	applog "{{ module_path }}/internal/logging"
)

func main() {
	cfg, err := config.Load()
	if err != nil {
		// Bootstrap-phase failure: no logger yet, so write to stderr
		// and exit. This is the ONLY place main returns non-zero
		// without going through slog.
		_, _ = os.Stderr.WriteString("config load failed: " + err.Error() + "\n")
		os.Exit(2)
	}
	logger := applog.New(cfg.LogLevel)
	slog.SetDefault(logger)

	ctx, stop := signal.NotifyContext(context.Background(), os.Interrupt, syscall.SIGTERM)
	defer stop()

	store, err := db.Open(ctx, cfg)
	if err != nil {
		logger.Error("db open failed", "err", err)
		os.Exit(3)
	}
	defer store.Close()

	handler := api.NewRouter(cfg, logger, store)

	srv := &http.Server{
		Addr:              cfg.Addr,
		Handler:           handler,
		ReadHeaderTimeout: 5 * time.Second,
		ReadTimeout:       30 * time.Second,
		WriteTimeout:      30 * time.Second,
		IdleTimeout:       60 * time.Second,
	}

	go func() {
		logger.Info("{{ project_name }} starting", "addr", cfg.Addr, "env", cfg.AppEnv)
		if err := srv.ListenAndServe(); err != nil && !errors.Is(err, http.ErrServerClosed) {
			logger.Error("listen failed", "err", err)
			stop()
		}
	}()

	<-ctx.Done()
	logger.Info("shutdown signal received, draining connections")

	shutdownCtx, cancel := context.WithTimeout(context.Background(), 15*time.Second)
	defer cancel()
	if err := srv.Shutdown(shutdownCtx); err != nil {
		logger.Error("graceful shutdown failed", "err", err)
		os.Exit(1)
	}
	logger.Info("{{ project_name }} stopped")
}
