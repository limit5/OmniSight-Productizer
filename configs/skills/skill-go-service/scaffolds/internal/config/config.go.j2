package config

import (
	"fmt"
	"strings"

	"github.com/kelseyhightower/envconfig"
)

// Settings aggregates every runtime knob. Populate via Load(); do NOT
// instantiate directly in tests — use ForTest instead.
type Settings struct {
	AppEnv      string   `envconfig:"APP_ENV" default:"dev"`
	LogLevel    string   `envconfig:"LOG_LEVEL" default:"info"`
	Addr        string   `envconfig:"ADDR" default:":8080"`
	DatabaseURL string   `envconfig:"DATABASE_URL" default:""`
	CORSOrigins []string `envconfig:"CORS_ORIGINS" default:"*"`
}

// Load parses env vars into Settings. Returns an error if the shape
// is wrong (e.g. unparsable bool) — caller in main exits on failure,
// which is the only place in the program that calls os.Exit on config.
func Load() (*Settings, error) {
	var s Settings
	if err := envconfig.Process("", &s); err != nil {
		return nil, fmt.Errorf("envconfig: %w", err)
	}
	s.LogLevel = strings.ToLower(s.LogLevel)
	if err := s.Validate(); err != nil {
		return nil, err
	}
	return &s, nil
}

// ForTest returns a Settings wired for unit tests — no network, no
// env var dependency. Tests mutate returned fields directly.
func ForTest() *Settings {
	return &Settings{
		AppEnv:      "test",
		LogLevel:    "error",
		Addr:        "127.0.0.1:0",
		DatabaseURL: "",
		CORSOrigins: []string{"*"},
	}
}

func (s *Settings) Validate() error {
	switch s.LogLevel {
	case "debug", "info", "warn", "error":
	default:
		return fmt.Errorf("LOG_LEVEL must be one of debug|info|warn|error, got %q", s.LogLevel)
	}
	if s.Addr == "" {
		return fmt.Errorf("ADDR must be non-empty")
	}
	return nil
}
