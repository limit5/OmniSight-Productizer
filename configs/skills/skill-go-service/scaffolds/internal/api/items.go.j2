func (h *Handlers) listItemsGin(c *gin.Context) {
	items, err := h.Store.List(c.Request.Context())
	if err != nil {
		h.Logger.Error("list items failed", "err", err)
		c.JSON(http.StatusInternalServerError, errorResponse{Error: err.Error()})
		return
	}
	c.JSON(http.StatusOK, items)
}

func (h *Handlers) createItemGin(c *gin.Context) {
	var req itemRequest
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, errorResponse{Error: err.Error()})
		return
	}
	if req.ID == "" || req.Name == "" {
		c.JSON(http.StatusUnprocessableEntity, errorResponse{Error: "id and name are required"})
		return
	}
	item, err := h.Store.Create(c.Request.Context(), db.Item{ID: req.ID, Name: req.Name, Notes: req.Notes})
	if err != nil {
		h.Logger.Error("create item failed", "err", err)
		c.JSON(http.StatusInternalServerError, errorResponse{Error: err.Error()})
		return
	}
	c.JSON(http.StatusCreated, item)
}

func (h *Handlers) getItemGin(c *gin.Context) {
	item, err := h.Store.Get(c.Request.Context(), c.Param("id"))
	if errors.Is(err, db.ErrNotFound) {
		c.JSON(http.StatusNotFound, errorResponse{Error: "not found"})
		return
	}
	if err != nil {
		h.Logger.Error("get item failed", "err", err)
		c.JSON(http.StatusInternalServerError, errorResponse{Error: err.Error()})
		return
	}
	c.JSON(http.StatusOK, item)
}

func (h *Handlers) deleteItemGin(c *gin.Context) {
	err := h.Store.Delete(c.Request.Context(), c.Param("id"))
	if errors.Is(err, db.ErrNotFound) {
		c.JSON(http.StatusNotFound, errorResponse{Error: "not found"})
		return
	}
	if err != nil {
		h.Logger.Error("delete item failed", "err", err)
		c.JSON(http.StatusInternalServerError, errorResponse{Error: err.Error()})
		return
	}
	c.Status(http.StatusNoContent)
}
