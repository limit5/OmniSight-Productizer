// itemRequest is the wire payload for create. Separate from db.Item
// so we can reject client-supplied IDs later without changing the
// domain model.
type itemRequest struct {
	ID    string `json:"id"`
	Name  string `json:"name"`
	Notes string `json:"notes,omitempty"`
}

type errorResponse struct {
	Error string `json:"error"`
}

