func (h *Handlers) listItemsFiber(c *fiber.Ctx) error {
	items, err := h.Store.List(c.UserContext())
	if err != nil {
		h.Logger.Error("list items failed", "err", err)
		return c.Status(http.StatusInternalServerError).JSON(errorResponse{Error: err.Error()})
	}
	return c.Status(http.StatusOK).JSON(items)
}

func (h *Handlers) createItemFiber(c *fiber.Ctx) error {
	var req itemRequest
	if err := c.BodyParser(&req); err != nil {
		return c.Status(http.StatusBadRequest).JSON(errorResponse{Error: err.Error()})
	}
	if req.ID == "" || req.Name == "" {
		return c.Status(http.StatusUnprocessableEntity).JSON(errorResponse{Error: "id and name are required"})
	}
	item, err := h.Store.Create(c.UserContext(), db.Item{ID: req.ID, Name: req.Name, Notes: req.Notes})
	if err != nil {
		h.Logger.Error("create item failed", "err", err)
		return c.Status(http.StatusInternalServerError).JSON(errorResponse{Error: err.Error()})
	}
	return c.Status(http.StatusCreated).JSON(item)
}

func (h *Handlers) getItemFiber(c *fiber.Ctx) error {
	item, err := h.Store.Get(c.UserContext(), c.Params("id"))
	if errors.Is(err, db.ErrNotFound) {
		return c.Status(http.StatusNotFound).JSON(errorResponse{Error: "not found"})
	}
	if err != nil {
		h.Logger.Error("get item failed", "err", err)
		return c.Status(http.StatusInternalServerError).JSON(errorResponse{Error: err.Error()})
	}
	return c.Status(http.StatusOK).JSON(item)
}

func (h *Handlers) deleteItemFiber(c *fiber.Ctx) error {
	err := h.Store.Delete(c.UserContext(), c.Params("id"))
	if errors.Is(err, db.ErrNotFound) {
		return c.Status(http.StatusNotFound).JSON(errorResponse{Error: "not found"})
	}
	if err != nil {
		h.Logger.Error("delete item failed", "err", err)
		return c.Status(http.StatusInternalServerError).JSON(errorResponse{Error: err.Error()})
	}
	return c.SendStatus(http.StatusNoContent)
}
