//
// Router wiring. The framework knob ({{ framework }}) is selected at
// render time — runtime code sees only the chosen engine. Contract
// both frameworks honour: http.Handler shape so httptest in tests
// and net/http.Server in main.go consume the same value.

package api

import (
	"log/slog"
	"net/http"

{%- if framework == "gin" %}

	"github.com/gin-gonic/gin"
{%- else %}

	"github.com/gofiber/fiber/v2"
	"github.com/gofiber/fiber/v2/middleware/adaptor"
{%- endif %}

	"{{ module_path }}/internal/config"
	"{{ module_path }}/internal/db"
)

// Handlers bundles dependencies every HTTP handler needs. Exported
// for tests — callers construct this directly rather than relying on
// a package-level singleton.
type Handlers struct {
	Cfg    *config.Settings
	Logger *slog.Logger
	Store  db.Store
}

// NewRouter builds the framework engine and returns it as a
// http.Handler so main.go stays framework-agnostic.
func NewRouter(cfg *config.Settings, logger *slog.Logger, store db.Store) http.Handler {
	h := &Handlers{Cfg: cfg, Logger: logger, Store: store}
{%- if framework == "gin" %}

	gin.SetMode(ginModeFromEnv(cfg.AppEnv))
	engine := gin.New()
	engine.Use(gin.Recovery())

	v1 := engine.Group("/api/v1")
	{
		v1.GET("/health", h.healthGin)
		v1.GET("/items", h.listItemsGin)
		v1.POST("/items", h.createItemGin)
		v1.GET("/items/:id", h.getItemGin)
		v1.DELETE("/items/:id", h.deleteItemGin)
	}
	return engine
}

func ginModeFromEnv(env string) string {
	switch env {
	case "prod", "production":
		return gin.ReleaseMode
	case "test":
		return gin.TestMode
	default:
		return gin.DebugMode
	}
}
{%- else %}

	app := fiber.New(fiber.Config{
		DisableStartupMessage: true,
	})
	v1 := app.Group("/api/v1")
	v1.Get("/health", h.healthFiber)
	v1.Get("/items", h.listItemsFiber)
	v1.Post("/items", h.createItemFiber)
	v1.Get("/items/:id", h.getItemFiber)
	v1.Delete("/items/:id", h.deleteItemFiber)

	// Adapt fiber's engine to net/http so main.go can consume it
	// uniformly with the gin branch.
	return adaptor.FiberApp(app)
}
{%- endif %}
