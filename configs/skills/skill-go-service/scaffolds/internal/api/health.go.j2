// Liveness endpoint. Returns 200 + {"status":"ok"} once the HTTP
// server is serving. Readiness semantics (DB reachable) would live in
// a separate /readyz later — the scaffold keeps /health simple.

package api

import (
	"net/http"
{%- if framework == "gin" %}

	"github.com/gin-gonic/gin"
{%- else %}

	"github.com/gofiber/fiber/v2"
{%- endif %}
)

// HealthResponse is the shape /api/v1/health returns. Kept tiny —
// probes call this on a tight loop so the JSON payload must stay
// cheap to marshal.
type HealthResponse struct {
	Status  string `json:"status"`
	Service string `json:"service"`
}

{% if framework == "gin" -%}
func (h *Handlers) healthGin(c *gin.Context) {
	c.JSON(http.StatusOK, HealthResponse{
		Status:  "ok",
		Service: "{{ project_name }}",
	})
}
{%- else -%}
func (h *Handlers) healthFiber(c *fiber.Ctx) error {
	return c.Status(http.StatusOK).JSON(HealthResponse{
		Status:  "ok",
		Service: "{{ project_name }}",
	})
}
{%- endif %}
