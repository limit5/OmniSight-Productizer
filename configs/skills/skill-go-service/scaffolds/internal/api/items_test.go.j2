func TestItemsCRUDRoundTrip(t *testing.T) {
	srv := httptest.NewServer(newTestRouter(t))
	defer srv.Close()

	client := srv.Client()

	// Create
	body, _ := json.Marshal(map[string]string{"id": "abc", "name": "Widget", "notes": "first"})
	resp, err := client.Post(srv.URL+"/api/v1/items", "application/json", bytes.NewReader(body))
	require.NoError(t, err)
	require.Equal(t, http.StatusCreated, resp.StatusCode)
	var created db.Item
	require.NoError(t, json.NewDecoder(resp.Body).Decode(&created))
	resp.Body.Close()
	require.Equal(t, "abc", created.ID)

	// List
	resp, err = client.Get(srv.URL + "/api/v1/items")
	require.NoError(t, err)
	require.Equal(t, http.StatusOK, resp.StatusCode)
	var list []db.Item
	require.NoError(t, json.NewDecoder(resp.Body).Decode(&list))
	resp.Body.Close()
	require.Len(t, list, 1)

	// Get
	resp, err = client.Get(srv.URL + "/api/v1/items/abc")
	require.NoError(t, err)
	require.Equal(t, http.StatusOK, resp.StatusCode)
	resp.Body.Close()

	// Delete
	req, _ := http.NewRequest(http.MethodDelete, srv.URL+"/api/v1/items/abc", nil)
	resp, err = client.Do(req)
	require.NoError(t, err)
	require.Equal(t, http.StatusNoContent, resp.StatusCode)
	resp.Body.Close()

	// Get-after-delete → 404
	resp, err = client.Get(srv.URL + "/api/v1/items/abc")
	require.NoError(t, err)
	require.Equal(t, http.StatusNotFound, resp.StatusCode)
	resp.Body.Close()
}

