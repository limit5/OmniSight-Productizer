import { NextRequest, NextResponse } from "next/server"
import { sendContactEmail } from "@/server/email"
{% if prisma %}import { db } from "@/server/db"
{% endif %}
export const runtime = "nodejs"

export async function POST(req: NextRequest) {
  const body = await req.json()
  const email = String(body.email || "")
  const subject = String(body.subject || "")
  const message = String(body.message || "")

  if (!email.includes("@") || subject.length < 3 || message.length < 10) {
    return NextResponse.json({ error: "invalid_contact_request" }, { status: 400 })
  }

  await sendContactEmail({ fromEmail: email, subject, body: message })
{% if prisma %}
  await db.message.create({
    data: {
      email,
      subject,
      body: message,
    },
  })
{% endif %}

  return NextResponse.json({ ok: true })
}
