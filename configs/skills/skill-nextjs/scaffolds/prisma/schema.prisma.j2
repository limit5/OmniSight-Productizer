// Generated by SKILL-NEXTJS (W6 #280). PRISMA=on.
// Baseline schema for the FS.7.1 Next.js + Prisma + Auth.js + tRPC
// + Resend bundle. Keep provider/env generic so operators can point
// the scaffold at local Postgres, Neon, Supabase, or RDS.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  messages      Message[]
}

model Message {
  id        String   @id @default(cuid())
  email     String
  subject   String
  body      String
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}
