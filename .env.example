# ─── OmniSight Engine Configuration ───
# Copy this file to .env and fill in your API keys.
# All backend env vars use the OMNISIGHT_ prefix.

# Active LLM provider: anthropic | google | openai | xai | groq | deepseek | together | ollama
OMNISIGHT_LLM_PROVIDER=anthropic

# Override model name (leave empty for provider default)
# OMNISIGHT_LLM_MODEL=

# ─── API Keys (set the one matching your chosen provider) ───
OMNISIGHT_ANTHROPIC_API_KEY=
OMNISIGHT_GOOGLE_API_KEY=
OMNISIGHT_OPENAI_API_KEY=
OMNISIGHT_XAI_API_KEY=
OMNISIGHT_GROQ_API_KEY=
OMNISIGHT_DEEPSEEK_API_KEY=
OMNISIGHT_TOGETHER_API_KEY=

# Ollama (local, no key needed)
# OMNISIGHT_OLLAMA_BASE_URL=http://localhost:11434

# ─── RTK Output Compression ───
# Enable/disable output compression for token savings
# OMNISIGHT_RTK_ENABLED=true
# Only compress outputs larger than this (bytes)
# OMNISIGHT_RTK_COMPRESSION_THRESHOLD=1000

# ─── Git Authentication ───
# SSH key path for private repos (default: ~/.ssh/id_ed25519)
# OMNISIGHT_GIT_SSH_KEY_PATH=~/.ssh/id_ed25519

# GitHub Personal Access Token (for HTTPS auth + PR creation)
# OMNISIGHT_GITHUB_TOKEN=ghp_...

# GitLab Personal Access Token (for HTTPS auth + MR creation)
# OMNISIGHT_GITLAB_TOKEN=glpat-...

# Self-hosted GitLab URL (leave empty for gitlab.com)
# OMNISIGHT_GITLAB_URL=https://gitlab.company.com

# ─── Gerrit Code Review ───
# Enable Gerrit integration (set to true to use Gerrit as review gateway)
# OMNISIGHT_GERRIT_ENABLED=true

# Gerrit web UI URL
# OMNISIGHT_GERRIT_URL=https://gerrit.example.com

# Gerrit SSH host and port (for git push + CLI commands)
# OMNISIGHT_GERRIT_SSH_HOST=gerrit.example.com
# OMNISIGHT_GERRIT_SSH_PORT=29418

# Gerrit project path
# OMNISIGHT_GERRIT_PROJECT=project/omnisight-core

# Post-merge replication targets (comma-separated remote names)
# OMNISIGHT_GERRIT_REPLICATION_TARGETS=github,gitlab

# ─── Frontend (Next.js) API Keys ───
# These are used when calling LLMs directly from the frontend via /api/chat
ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# OPENAI_API_KEY=
# XAI_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# TOGETHER_AI_API_KEY=

# Backend URL (for frontend API client and Next.js rewrite proxy)
# NEXT_PUBLIC_API_URL=http://localhost:8000
# BACKEND_URL=http://localhost:8000    # Used by next.config.mjs rewrite (Docker: http://backend:8000)

# ─── Production / Docker Settings ───
# OMNISIGHT_DEBUG=false                # Set to false for production (default: false)
# OMNISIGHT_FRONTEND_ORIGIN=https://omnisight.company.com  # Public frontend URL for CORS
# OMNISIGHT_EXTRA_CORS_ORIGINS=        # Additional CORS origins, comma-separated
# OMNISIGHT_DATABASE_PATH=             # SQLite path (empty = default data/omnisight.db)
# OMNISIGHT_DOCKER_IMAGE=omnisight-agent:latest  # Agent sandbox image name
# Phase 64-A S1: Tier-1 sandbox runtime. "runsc" (gVisor) blocks most
# container-escape CVEs via a user-space kernel; auto-falls back to
# "runc" if gVisor isn't installed (dev / WSL2 / mac).
# OMNISIGHT_DOCKER_RUNTIME=runsc
# Phase 64-A S2: Tier-1 egress whitelist. DOUBLE-GATED. Both must be
# set to open the air-gap; otherwise sandbox stays --network none.
# After flipping these on, run scripts/setup_t1_egress_iptables.sh as
# root on each host to install the iptables ACCEPT/DROP rules.
# OMNISIGHT_T1_ALLOW_EGRESS=false
# OMNISIGHT_T1_EGRESS_ALLOW_HOSTS=github.com,gerrit.internal:29418
# Phase 64-A S3: agent docker image digest allow-list. Empty = no
# check (today's behaviour). Set in prod to refuse a tampered image:
# `docker image inspect --format '{{.Id}}' omnisight-agent:<tag>`
# OMNISIGHT_DOCKER_IMAGE_ALLOWED_DIGESTS=sha256:abc...,sha256:def...
# Phase 64-A S4: sandbox wall-clock lifetime cap. After this many
# seconds the watchdog SIGKILLs the container even if its commands
# look in-progress. 0 = disabled (NOT recommended in prod). Default
# 2700 = 45 min, matches the design spec.
# OMNISIGHT_SANDBOX_LIFETIME_S=2700
# Phase 64-D D3: per-exec output cap. Truncates docker exec output
# above this byte count + appends a marker. Defends Tier-0 LLM
# context. 0 = disabled (default 10 KB).
# OMNISIGHT_SANDBOX_MAX_OUTPUT_BYTES=10000
# Phase 67-A: prompt cache marker injection. Default ON (recommended
# in prod for both cost and TTFT). Set to false only for debug.
# OMNISIGHT_PROMPT_CACHE_ENABLED=true
# Phase 67-D: RAG pre-fetch on step error. v1 confidence floor 0.5;
# raise to 0.7 after Phase 63-E memory decay lands.
# OMNISIGHT_RAG_MIN_CONFIDENCE=0.5
# OMNISIGHT_RAG_TOP_K=3
# Phase 67-B: write_file existing-file-overwrite cap.
# OMNISIGHT_PATCH_MAX_INLINE_LINES=50
# Phase 67-C: speculative pre-warm depth (how many in-degree-0 tasks
# to pre-launch a container for).
# OMNISIGHT_PREWARM_DEPTH=2
# Phase 65 S2: fine-tune hold-out regression threshold. Candidate
# weighted score must be >= baseline - this many percentage points
# OR the promotion is rejected. Default 5pp.
# OMNISIGHT_FINETUNE_REGRESSION_PP=5
# Phase 65 S3: fine-tune backend. noop|openai|unsloth.
#   noop    — synthetic handle; default; safe for dev / opt-out prod.
#   openai  — uses openai SDK; requires OPENAI_API_KEY.
#   unsloth — local unsloth-cli; production callers MUST wrap the
#             subprocess in a Tier-2 sandbox (Phase 64-B) for hub egress.
# OMNISIGHT_FINETUNE_BACKEND=noop
# Phase 63-E: episodic memory quality decay (L3 opt-in).
# TTL — rows untouched for this many seconds get their decayed_score
# multiplied by FACTOR each pass. Never deletes — only down-weights.
# OMNISIGHT_MEMORY_DECAY_TTL_S=7776000    # 90 days
# OMNISIGHT_MEMORY_DECAY_FACTOR=0.9       # 10% decay per pass
# OMNISIGHT_MEMORY_DECAY_INTERVAL_S=86400 # nightly
# L1-06: hourly LLM burn-rate kill-switch. A daily cap catches drift;
# the hourly cap catches spikes that would blow a month's budget in
# a few hours but stay under daily. 0 = disabled. Rule of thumb:
# token_budget_daily / 12.
# OMNISIGHT_TOKEN_BUDGET_HOURLY=0.0

# ─── Internet-exposure auth (Phase 54 + S1-S3) ───
# IF YOU ARE EXPOSING THIS URL TO THE INTERNET, READ THIS BLOCK.
#
# Auth mode. open=anyone-is-admin (dev only). session=cookie required
# for mutators. strict=cookie + CSRF for everything except /healthz +
# /auth/login. Production deploys MUST set this to `strict`.
# OMNISIGHT_AUTH_MODE=strict

# Bootstrap admin. Created on first boot if the users table is empty.
# DO NOT keep the default password 'omnisight-admin' on an exposed
# URL — config validation will refuse to start the app in prod if you
# do. Use a passphrase ≥ 12 chars.
# OMNISIGHT_ADMIN_EMAIL=you@example.com
# OMNISIGHT_ADMIN_PASSWORD=correct-horse-battery-staple-please-replace

# Cookie Secure flag. Cloudflare Tunnel terminates HTTPS, so behind it
# the answer is always 'true' — set this so session cookies refuse to
# travel over a future plain-HTTP path (custom dev proxies, etc.).
# OMNISIGHT_COOKIE_SECURE=true

# /auth/login brute-force defence. 5 fails in 15 min → 429 with
# Retry-After. Tighten under attack; loosen if your team shares a
# NAT and trips it innocently.
# OMNISIGHT_LOGIN_MAX_ATTEMPTS=5
# OMNISIGHT_LOGIN_WINDOW_S=900
# Phase 67-E: Tier-1 sandbox RAG pre-fetch (stricter guards).
# Similarity (proxy) floor — borderline matches rejected, cosine-style.
# OMNISIGHT_RAG_MIN_COSINE=0.85
# Total token budget for the injected <system_auto_prefetch> block.
# OMNISIGHT_RAG_MAX_BLOCK_TOKENS=1000

# ─── Phase 47 Decision Engine tuning ───
# [DEPRECATED by K6] Legacy single bearer token. If set, K6 auto-migrates it
# to an api_keys row on startup. Use Admin UI > API Keys to create per-service
# keys instead, then remove this env var.
# OMNISIGHT_DECISION_BEARER=

# Max pending decisions before proposers receive DecisionQueueFull (default 256).
# OMNISIGHT_DECISION_PENDING_MAX=256

# Timeout sweep cadence in seconds (default 10).
# OMNISIGHT_DECISION_SWEEP_INTERVAL_S=10

# Sliding-window rate limit on decision mutators, per client IP.
# OMNISIGHT_DECISION_RL_WINDOW_S=10
# OMNISIGHT_DECISION_RL_MAX=30

# ─── Runtime limits ───
# Max bytes a single `bash` tool call may return (default 128 KB).
# OMNISIGHT_BASH_TIMEOUT=120

# Hard cap on SDK clone size before cleanup (default 8192 MB).
# OMNISIGHT_SDK_CLONE_MAX_MB=8192

# Git credentials YAML path (default: configs/git_credentials.yaml).
# OMNISIGHT_GIT_CREDENTIALS_FILE=
