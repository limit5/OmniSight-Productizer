# Pytest-only config (2026-04-21). Loaded by backend.config when
# OMNISIGHT_DOTENV_FILE points here — see backend/tests/conftest.py,
# which sets the path and unsets known-leaky live env vars BEFORE
# any backend module imports.
#
# Rationale: developer workstations have ``.env`` with REAL production
# credentials (anthropic key, CF tunnel token, production frontend
# hostname). Under the pre-2026-04-21 pytest setup, those bled into
# tests via pydantic-settings' .env loader → "fresh install"
# assertions failed on any workstation where .env had the usual
# provider creds set. This file is the safe-default counterweight.
#
# DO NOT put real credentials here. Everything here is a known-safe
# default that unblocks the "fresh install" / "no external services"
# test assumptions.

# Core app
OMNISIGHT_ENV=test
OMNISIGHT_DEBUG=true
OMNISIGHT_AUTH_MODE=open
OMNISIGHT_ADMIN_EMAIL=admin@test.local

# LLM provider — empty so _llm_provider_is_configured() returns
# False and the bootstrap wizard sees "needs config".
OMNISIGHT_LLM_PROVIDER=
OMNISIGHT_ANTHROPIC_API_KEY=
OMNISIGHT_GOOGLE_API_KEY=
OMNISIGHT_OPENAI_API_KEY=
OMNISIGHT_XAI_API_KEY=
OMNISIGHT_GROQ_API_KEY=
OMNISIGHT_DEEPSEEK_API_KEY=
OMNISIGHT_TOGETHER_API_KEY=
OMNISIGHT_OPENROUTER_API_KEY=

# CF tunnel — empty so _cf_tunnel_is_configured() returns False.
OMNISIGHT_CLOUDFLARE_TUNNEL_TOKEN=
OMNISIGHT_PUBLIC_HOSTNAME=
OMNISIGHT_CF_TUNNEL_SKIP=

# Frontend origin — point at localhost so health-check stubs can
# match (production .env has the prod hostname here).
OMNISIGHT_FRONTEND_ORIGIN=http://localhost:3000
OMNISIGHT_NEXT_PUBLIC_API_URL=http://localhost:8000

# Strict-mode gates — tests that want strict mode monkeypatch
# these explicitly; the defaults keep open mode viable.
OMNISIGHT_ADMIN_PASSWORD=
OMNISIGHT_DECISION_BEARER=

# Notifications + CI integrations — all empty so tests don't
# accidentally ping Slack / Jira / PagerDuty from a CI run.
OMNISIGHT_NOTIFICATION_SLACK_WEBHOOK=
OMNISIGHT_NOTIFICATION_JIRA_URL=
OMNISIGHT_NOTIFICATION_PAGERDUTY_KEY=
OMNISIGHT_CHATOPS_DISCORD_WEBHOOK=
OMNISIGHT_CHATOPS_TEAMS_WEBHOOK=
OMNISIGHT_CHATOPS_LINE_CHANNEL_TOKEN=

# Git / Gerrit / GitHub tokens — empty.
OMNISIGHT_GITHUB_TOKEN=
OMNISIGHT_GITLAB_TOKEN=
OMNISIGHT_GERRIT_URL=
OMNISIGHT_CI_JENKINS_URL=
OMNISIGHT_CI_JENKINS_USER=
OMNISIGHT_CI_JENKINS_API_TOKEN=

# DB — leave unset; pg_test_pool / pg_test_dsn fixtures manage.
