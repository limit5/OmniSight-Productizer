FROM python:3.12-slim

WORKDIR /app

# System deps for uvicorn[standard] (uvloop, httptools) + git
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ git openssh-client curl \
    && rm -rf /var/lib/apt/lists/*

# Python deps — N1 policy: hashed lockfile, fail if any transitive
# wheel hash doesn't match the lock. `requirements.txt` is generated
# from `backend/requirements.in` via `pip-compile --generate-hashes`.
COPY backend/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir --require-hashes -r requirements.txt

# Application code
COPY backend/ ./backend/
COPY configs/ ./configs/
COPY scripts/ ./scripts/
COPY CLAUDE.md ./
COPY .env.example ./.env.example

# Data directory (mount as volume for persistence)
RUN mkdir -p /app/data /app/.artifacts /app/.sdks

ENV OMNISIGHT_WORKSPACE=/app
ENV OMNISIGHT_DEBUG=false
ENV OMNISIGHT_AUTH_MODE=strict
ENV OMNISIGHT_DATABASE_PATH=/app/data/omnisight.db

EXPOSE 8000

# I10: OMNISIGHT_WORKERS env controls worker count (default: CPU/2, min 2).
# Requires OMNISIGHT_REDIS_URL for cross-worker shared state.
ENV OMNISIGHT_WORKERS=""
CMD ["sh", "-c", "WORKERS=${OMNISIGHT_WORKERS:-$(python3 -c 'import os; print(max(2, os.cpu_count() // 2))')}; exec python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000 --workers $WORKERS"]
