# L10 #337: multi-stage build keeps the compiler toolchain out of the
# runtime image. `builder` installs all packages with gcc/g++ available;
# `runner` copies only the installed site-packages.
#
# Before: single-stage with gcc/g++/git in runtime → 1.34 GB.
# After:  multi-stage + test-pkg strip + recursive .dockerignore → ~370 MB.

# ── Builder ──────────────────────────────────────────────────────────
FROM python:3.12-slim AS builder

WORKDIR /build

# Build-time deps only — needed to compile native wheels (uvloop,
# pillow, cryptography, argon2-cffi, hiredis, …) when the lockfile
# pins a version without a manylinux/musllinux prebuilt wheel. None
# of this ships in the runner.
RUN apt-get update && apt-get install -y --no-install-recommends \
        gcc g++ git curl \
    && rm -rf /var/lib/apt/lists/*

# N1 policy: hashed lockfile; a drift in requirements.in fails CI.
COPY backend/requirements.txt ./requirements.txt

# Install to the system site-packages (the runner will COPY --from=builder
# that directory wholesale). We deliberately do NOT use `pip wheel` +
# `pip install --no-index --find-links` — that pattern rebuilds sdists
# into wheels whose hashes differ from the pypi-registered ones, so the
# runner's `--require-hashes` install fails on any package lacking a
# prebuilt wheel (zxcvbn-python et al).
RUN pip install --no-cache-dir --require-hashes -r requirements.txt

# Drop test-only packages from the prod runtime — production code never
# imports pytest (verified: `grep -rln '^import pytest\|^from pytest'
# backend/` excluding tests/ returns empty). Run as a separate RUN so
# a non-zero exit is immediately visible (an earlier draft used a long
# `&& ... || true` chain that silently masked a hash-verification failure).
RUN pip uninstall -y pytest pytest-asyncio pytest-cov coverage iniconfig pluggy

# Strip pip itself + bytecode caches + unused WOFF2 compressors from
# site-packages. The runtime never `pip install`s anything, so pip is
# dead weight. zstandard (23 MB) + zopfli (2.7 MB) are fontTools[woff]
# extras for WOFF2 compression — weasyprint generates PDFs, not WOFF2
# fonts, so they are unused. Smoke-tested: `weasyprint.HTML(...).write_pdf()`
# produces identical output with zstandard+zopfli removed.
RUN rm -rf /usr/local/lib/python3.12/site-packages/pip \
           /usr/local/lib/python3.12/site-packages/pip-*.dist-info \
           /usr/local/lib/python3.12/site-packages/zstandard \
           /usr/local/lib/python3.12/site-packages/zstandard-*.dist-info \
           /usr/local/lib/python3.12/site-packages/zopfli \
           /usr/local/lib/python3.12/site-packages/zopfli-*.dist-info \
    && find /usr/local/lib/python3.12 -name '__pycache__' -type d -exec rm -rf {} + \
    && find /usr/local/lib/python3.12 -name '*.pyc' -delete


# ── Runner ───────────────────────────────────────────────────────────
FROM python:3.12-slim AS runner

WORKDIR /app

# Runtime OS libs only. weasyprint needs Pango/Cairo/gdk-pixbuf at
# import time — without these, `from backend.reports import ...` crashes
# in production. `fonts-dejavu-core` provides a default font face so
# PDF rendering doesn't fall back to blank glyph boxes.
# No compilers, no git, no ssh — ~300 MB smaller than the prior image.
RUN apt-get update && apt-get install -y --no-install-recommends \
        libpango-1.0-0 libpangoft2-1.0-0 libcairo2 libgdk-pixbuf-2.0-0 \
        libffi8 shared-mime-info fonts-dejavu-core \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Transport the pruned Python site-packages from builder. This is the
# only pip-produced surface the runtime needs — no /usr/local/bin copy
# because `python -m uvicorn` doesn't need the uvicorn entry-point
# script, and no /wheels cache because we installed directly.
#
# Note: `COPY <dir> <dir>` MERGES with the destination, so pip/setuptools
# that ship with the python:3.12-slim base survive the copy. We strip
# them + /usr/share/doc + stock bytecode caches right after to reclaim
# ~15 MB that would otherwise push us over the 500 MB gate.
COPY --from=builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages

RUN rm -rf /usr/local/lib/python3.12/site-packages/pip \
           /usr/local/lib/python3.12/site-packages/pip-*.dist-info \
           /usr/share/doc /usr/share/man /usr/share/bash-completion \
    && find /usr/local/lib/python3.12 -name '__pycache__' -type d -exec rm -rf {} + \
    && find /usr/local/lib/python3.12 -name '*.pyc' -delete

# Application code. `.dockerignore` keeps __pycache__/.venv out of the
# build context (recursive patterns — before the fix, backend/.venv
# silently leaked 168 MB of duplicate site-packages into the image).
# We still strip `backend/tests/` (31 MB) explicitly because tests are
# not part of the runtime contract.
COPY backend/ ./backend/
COPY configs/ ./configs/
COPY scripts/ ./scripts/
COPY CLAUDE.md ./
COPY .env.example ./.env.example
# R20 Phase 0 (2026-04-25): docs/ is required for the classification-
# gated RAG corpus that ``backend.rag`` walks at startup. Only docs
# whose audience matches the calling user's role become retrievable —
# ``internal``-tagged docs and any doc in an unrecognised directory
# stay invisible to chat. See ``backend/rag/corpus.py``.
COPY docs/ ./docs/
COPY README.md ./

RUN rm -rf ./backend/tests ./backend/.pytest_cache

# Data directory (mount as volume for persistence)
RUN mkdir -p /app/data /app/.artifacts /app/.sdks

# H4 audit (2026-04-19): non-root runtime. Matches Dockerfile.frontend's
# uid 65532 (distroless/nonroot convention; avoids conflating with uid
# 65534 "nobody"). Both services drop privilege → a hypothetical RCE in
# uvicorn is uid 65532 inside the container, which (combined with the
# C1 docker-socket-proxy's verb allow-list) can no longer pivot into
# arbitrary host-level operations. /app is chown'd at image-build time
# so fresh volume mounts inherit app:app; existing prod volumes (data /
# artifacts / sdks) need a one-time `docker run ... chown` outside the
# container because Docker doesn't retro-chown populated volumes on
# mount. The migration is documented in the H4-backend commit.
RUN groupadd -g 65532 app && \
    useradd  -u 65532 -g 65532 -M -s /usr/sbin/nologin app && \
    chown -R app:app /app

ENV OMNISIGHT_WORKSPACE=/app \
    OMNISIGHT_DEBUG=false \
    OMNISIGHT_AUTH_MODE=strict \
    OMNISIGHT_DATABASE_PATH=/app/data/omnisight.db

USER app:app

EXPOSE 8000

# I10: OMNISIGHT_WORKERS env controls worker count (default: CPU/2, min 2).
# Requires OMNISIGHT_REDIS_URL for cross-worker shared state. Not declared
# via ENV here — pydantic-settings reads OMNISIGHT_* env vars and rejects
# an empty string as `int`; leaving the env unset lets the class default
# (workers: int = 0 → auto) take over when operator hasn't overridden.
# H3 audit (2026-04-19): `--no-access-log` mirrors what the systemd
# unit already does (deploy/systemd/omnisight-backend.service:37). Caddy
# polls /readyz every 2 s during rolling deploys; uvicorn's INFO-level
# access log turns that into 30 lines/minute of probe noise that drowns
# out real request signals. Structured request observability lives in
# structlog middleware + explicit handler logs — uvicorn's TCP-style
# access log adds no value on top.
CMD ["sh", "-c", "WORKERS=${OMNISIGHT_WORKERS:-$(python3 -c 'import os; print(max(2, os.cpu_count() // 2))')}; exec python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000 --workers $WORKERS --no-access-log"]
