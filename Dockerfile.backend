FROM python:3.12-slim

WORKDIR /app

# System deps for uvicorn[standard] (uvloop, httptools) + git
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ git openssh-client curl \
    && rm -rf /var/lib/apt/lists/*

# Python deps
COPY backend/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Application code
COPY backend/ ./backend/
COPY configs/ ./configs/
COPY scripts/ ./scripts/
COPY CLAUDE.md ./
COPY .env.example ./.env.example

# Data directory (mount as volume for persistence)
RUN mkdir -p /app/data /app/.artifacts /app/.sdks

ENV OMNISIGHT_WORKSPACE=/app
ENV OMNISIGHT_DEBUG=false
ENV OMNISIGHT_AUTH_MODE=strict
ENV OMNISIGHT_DATABASE_PATH=/app/data/omnisight.db

EXPOSE 8000

CMD ["python", "-m", "uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
