# OmniSight Productizer — Reverse proxy (G2 / HA-02 #1)
#
# Frontside HTTPS :443 terminator that fronts two backend replicas
# (backend-a:8000, backend-b:8001) sharing the same volumes.
#
# Why Caddy: auto-TLS (ACME / internal issuer), zero-config HTTP/2 + HTTP/3,
# native active health checks + passive `fail_timeout` eject, and a concise
# load-balancing stanza that maps 1:1 onto the rolling-restart flow we need
# in TODO.md G2 checkbox #3 (取下 A → 重啟 → /readyz pass → 取下 B → 重啟).
#
# This file is the **deliverable for TODO row 1345 only**:
#   - listen on :443
#   - upstream = { backend-a:8000, backend-b:8001 }
#
# The companion items (docker-compose dual replica, rolling deploy.sh,
# fail_timeout tuning, integration-soak test) land in subsequent G2 commits
# and will extend this file in place — the load-balance block is the anchor.
#
# Operator knobs (env → Caddy globals):
#   OMNISIGHT_PUBLIC_HOSTNAME  — ACME hostname. Default :443 (any SNI) so
#                                first-boot with `tls internal` works on
#                                a bare VM without DNS plumbing.
#   OMNISIGHT_ACME_EMAIL       — ACME registration email. Empty ⇒ internal CA.
#   OMNISIGHT_UPSTREAM_A       — override backend-a address. Default backend-a:8000.
#   OMNISIGHT_UPSTREAM_B       — override backend-b address. Default backend-b:8001.
#
# Smoke: `caddy validate --config deploy/reverse-proxy/Caddyfile --adapter caddyfile`
#        `caddy fmt --overwrite deploy/reverse-proxy/Caddyfile`

{
	# Global options — kept explicit so `caddy validate` is deterministic in CI.
	admin off
	auto_https disable_redirects
	# `email` requires a non-empty argument or Caddy refuses to parse the
	# config. If OMNISIGHT_ACME_EMAIL is unset we fall through to
	# `issuer internal` (self-signed CA), in which case this placeholder
	# is never actually used by ACME.
	email {$OMNISIGHT_ACME_EMAIL:admin@omnisight.invalid}
	servers {
		protocols h1 h2 h2c h3
	}
}

# HTTP :80 → HTTPS :443 redirect (host-agnostic so it works both for a bare
# IP deploy and the `OMNISIGHT_PUBLIC_HOSTNAME` deploy).
:80 {
	redir https://{host}{uri} permanent
}

# Internal HTTP :8000 — Docker-internal backend proxy for frontend SSR.
# Frontend's BACKEND_URL=http://caddy:8000 routes through here instead of
# directly to backend-a, so SSR survives rolling restart without OOM.
# NOT exposed to host (only Docker network). Same upstream pool + health
# checks as the :443 block.
#
# CAUTION: do NOT turn :8000 into a path-aware router — the container
# healthcheck in docker-compose.prod.yml probes `caddy:8000/readyz`
# and any catch-all fallback to frontend:3000 would break that probe
# (frontend has no /readyz). A dedicated edge router lives on :8080
# (see block below); :8000 stays pure "internal backend proxy".
:8000 {
	reverse_proxy {$OMNISIGHT_UPSTREAM_A:backend-a:8000} {$OMNISIGHT_UPSTREAM_B:backend-b:8001} {
		lb_policy round_robin
		lb_try_duration 5s
		lb_try_interval 250ms

		health_uri /readyz
		health_port 0
		health_method GET
		health_interval 2s
		health_timeout 2s
		health_status 2xx
		health_passes 1
		health_fails 3

		fail_duration 30s
		max_fails 3
		unhealthy_status 5xx

		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}

		flush_interval -1
	}
}

# Edge path router :8080 — Phase-3 Runtime P2 (2026-04-20).
#
# Purpose: canonical edge-routing pattern (Kubernetes Ingress / AWS ALB /
# Cloudflare Workers shape) that splits API traffic from UI traffic at
# the reverse-proxy layer, NOT inside the Next.js app.
#
# Why this block exists: CF Tunnel previously pointed its Public Hostname
# at `http://frontend:3000`, which made Next.js's `rewrites()` API the
# API gateway for `/api/v1/*` traffic. Next.js rewrites are well-known to
# buffer streaming responses (SSE, NDJSON, Transfer-Encoding: chunked) —
# the Node.js HTTP proxy layer doesn't forward `flush_interval`-style
# hints to the upstream fetch. Symptom: `/api/v1/events` SSE opens with
# 200 + headers, then the browser sees 0 bytes for 60+ s, treats the
# connection as dead, EventSource reconnects in a rapid loop, burns the
# per-IP rate-limit quota, login endpoint 429s, operator bounces back
# to /login. Same class of bug is documented across Next.js issue
# trackers since 2022 — it is not a regression, it is an unsupported
# use of `rewrites()`.
#
# The fix (this block): route /api/v1/* directly to the backend pool
# without Next.js involvement; route everything else to frontend:3000
# for SSR. Both handlers set `flush_interval -1` so streaming works
# end-to-end.
#
# Topology (after CF Tunnel dashboard flip to http://caddy:8080):
#
#   browser → CF edge → cloudflared → caddy:8080
#                                   ├── /api/v1/*  → backend-a/b
#                                   └── /*         → frontend:3000
#
# NOT exposed to host — only the docker `default` network, reachable by
# the cloudflared sidecar via DNS `caddy:8080`.
#
# Operator step required (one-time, outside code): in CF Zero Trust
# dashboard → Networks → Tunnels → <tunnel> → Public Hostnames, change
# the service URL from `http://frontend:3000` → `http://caddy:8080`.
# Rollback is the reverse — single dashboard setting, ~30 s.
:8080 {
	# Access log so we can diagnose CF-edge → cloudflared → caddy:8080
	# request patterns (each line includes method / URI / status / dur /
	# upstream). Phase-3 P2 follow-up after operator re-reported the
	# cascade even after the CF tunnel flip — need full visibility on
	# what the BROWSER sends vs what CADDY forwards to upstream, since
	# curl tests work but browser paths fail.
	log {
		output stdout
		format json
		level INFO
	}

	# API path handler — reverse_proxy to backend pool with the same
	# upstream list, health checks, and failure semantics as :443. The
	# ``flush_interval -1`` is what makes SSE work through this path:
	# it forces Caddy to write every byte received from the upstream
	# to the downstream socket immediately, without accumulating a
	# buffer. Without it, even a correctly-configured SSE producer
	# appears buffered to the client.
	handle /api/v1/* {
		reverse_proxy {$OMNISIGHT_UPSTREAM_A:backend-a:8000} {$OMNISIGHT_UPSTREAM_B:backend-b:8001} {
			lb_policy round_robin
			lb_try_duration 5s
			lb_try_interval 250ms

			health_uri /readyz
			health_port 0
			health_method GET
			health_interval 2s
			health_timeout 2s
			health_status 2xx
			health_passes 1
			health_fails 3

			fail_duration 30s
			max_fails 3
			unhealthy_status 5xx

			# Preserve original client identity for rate-limiter,
			# audit_log, account-lockout — they key on these.
			# cloudflared sets cf-connecting-ip; Caddy forwards it
			# here via header_up so the backend rate limiter sees
			# the real client IP, not the docker-internal addr.
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}

			flush_interval -1
		}
	}

	# UI / SSR handler — catch-all fallback. Next.js serves the dashboard
	# pages, static assets, and any route outside /api/v1/*. SSR itself
	# continues to reach the backend via ``BACKEND_URL=http://caddy:8000``
	# (the dedicated internal block above), so this handle can stay a
	# simple single-upstream proxy.
	handle {
		reverse_proxy frontend:3000 {
			# Next.js can stream (React 18+ renderToPipeableStream);
			# keep flushing hot so a future use of server-sent UI
			# streams works out of the box.
			flush_interval -1

			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
}

# Main HTTPS listener. Multi-name site so Caddy's internal CA pre-issues
# a cert for EACH declared name — required because `tls internal` with
# a bare `:443` catch-all won't mint certs for arbitrary SNIs and every
# TLS handshake ends in `alert internal error`. Declared names cover:
#   - $OMNISIGHT_PUBLIC_HOSTNAME (real hostname when set, e.g. sora-dev.app)
#   - localhost / 127.0.0.1 (loopback curl smoke + Caddy healthcheck)
{$OMNISIGHT_PUBLIC_HOSTNAME:localhost}, 127.0.0.1 {
	# TLS — Caddy's internal CA (self-signed).
	#
	# Production architecture: Cloudflare Tunnel terminates real TLS at
	# the CF edge, then forwards to this origin over the tunnel in plain
	# HTTP (or opportunistic TLS that ignores origin-cert validity). So
	# the origin `:443` cert only needs to exist, not be publicly trusted.
	#
	# Previous iteration used `tls { issuer acme; issuer internal }` as a
	# fallback chain, but when OMNISIGHT_PUBLIC_HOSTNAME is empty the
	# site address is `:443` (catch-all, no FQDN) and `issuer acme` has
	# nothing to validate against → its failure state poisoned the TLS
	# handshake with alert 80 `internal error`. Using `tls internal` only
	# gives a clean self-signed cert for any SNI (including 127.0.0.1).
	#
	# If you later need real ACME certs on this origin (direct access
	# bypassing CF), switch to `tls {$OMNISIGHT_ACME_EMAIL}` and set a
	# real hostname in OMNISIGHT_PUBLIC_HOSTNAME.
	tls internal

	# Standard hardening — HSTS only after a host is pinned; on bare `:443`
	# the preload list would be a footgun, so keep it off by default.
	header {
		-Server
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# Structured access log — JSON so the existing ELK / Loki stack (Phase 52
	# observability sidecars in docker-compose.prod.yml) can ingest directly.
	log {
		output stdout
		format json
		level INFO
	}

	# --- Reverse proxy to the dual backend replicas -------------------------
	#
	# Both replicas mount the same `omnisight-data` volume (see
	# docker-compose.prod.yml extension in G2 checkbox #2), so any request can
	# land on either one — the upstream pool is truly symmetric.
	#
	# `lb_policy round_robin` + `lb_try_duration 5s` gives even traffic under
	# steady state and a 5 s retry budget when one replica is being pulled for
	# rolling restart (scripts/deploy.sh G2 checkbox #3).
	#
	# Active health check hits the backend's `/readyz` (G1 deliverable) every
	# 2 s; a replica needs `fail_duration 30s` of failures before being ejected
	# from the pool — which matches TODO row 1348 "fail_timeout" semantics and
	# gives `deploy.sh` a predictable quiet window to restart the taken-down
	# instance.
	reverse_proxy {$OMNISIGHT_UPSTREAM_A:backend-a:8000} {$OMNISIGHT_UPSTREAM_B:backend-b:8001} {
		lb_policy round_robin
		lb_try_duration 5s
		lb_try_interval 250ms

		# Active probes — tight interval so a downed replica is pulled from the
		# pool within ~3 probes (≈6 s), matching the rolling-restart SLO.
		#
		# G2 #4 contract (TODO row 1348):
		#   - `health_method GET` is explicit so the probe never inherits the
		#     verb of a failed in-flight request (would skew /readyz observation).
		#   - `health_follow_redirects false` — /readyz returns 200 or 503 flat,
		#     a 3xx chain is a bug and should eject the upstream, not mask it.
		#   - `health_passes 1` / `health_fails 3` pins the state-flip threshold:
		#     one good probe re-inserts a drained replica (fast recovery after
		#     rolling restart), three consecutive bad probes eject it (~6 s at
		#     2 s interval — tight enough that Caddy pulls a dying replica before
		#     `deploy.sh` reaches it, loose enough that a single dropped probe
		#     on a GC pause doesn't flap the pool).
		health_uri /readyz
		health_port 0
		health_method GET
		health_interval 2s
		health_timeout 2s
		health_status 2xx
		health_passes 1
		health_fails 3
		# Caddy defaults to NOT following redirects — dropped explicit
		# `health_follow_redirects false` because it's a flag directive
		# (presence = on), not a boolean-taking one.

		# Passive eject — independent safety net for the case where a replica
		# returns 5xx *without* failing the /readyz probe (e.g. DB blip mid
		# request). This is the Caddy equivalent of nginx's
		# `fail_timeout` / `max_fails` pair: `fail_duration` is BOTH the
		# observation window AND the eject duration (nginx semantics exactly).
		#
		# Tuning rationale (TODO row 1348 — "fail_timeout"):
		#   - `fail_duration 30s` — one tenant's burst of 5xx won't eject for
		#     longer than it takes the operator to notice; short enough that
		#     an ejected replica re-enters the pool quickly once healthy.
		#   - `max_fails 3` — single DB blip (one 5xx) shouldn't eject; three
		#     within 30 s is a signal, not noise.
		#   - `unhealthy_request_count 50` — a flood of clients hitting one
		#     replica during a partial outage gets that replica ejected even
		#     if individual requests don't cross `max_fails` in the window.
		#   - `unhealthy_status 5xx` — 4xx is client error, never counts.
		#   - `unhealthy_latency 10s` — a replica that answers 200 but takes
		#     >10 s is worse than ejected; `backend/lifecycle.py` p99 is
		#     sub-second under nominal load.
		fail_duration 30s
		max_fails 3
		unhealthy_request_count 50
		unhealthy_status 5xx
		unhealthy_latency 10s

		# Forward the usual identity headers so the backend sees the real
		# client (rate-limiter, audit log, account-lockout all key on these).
		header_up Host {http.reverse_proxy.upstream.hostport}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}

		# Buffering off — the backend streams SSE for agent runs / debug
		# findings (backend/events.py) and long-lived WS-ish transports.
		flush_interval -1
	}
}
