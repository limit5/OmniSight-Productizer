# G4 #3 — OmniSight PostgreSQL HA environment template.
#
# Copy to deploy/postgres-ha/.env and fill in strong passwords BEFORE
# running `docker compose up -d`. Never commit the real .env file.

# --- Superuser / app database (same on primary and standby) -----------
POSTGRES_USER=omnisight
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=omnisight

# --- Replication role (created on primary, consumed by standby) -------
REPLICATION_USER=replicator
REPLICATION_PASSWORD=CHANGE_ME_STRONG_REPL_PASSWORD

# --- Primary connection parameters (as seen from the standby) ---------
PRIMARY_HOST=pg-primary
PRIMARY_PORT=5432

# --- Replication slot / application name ------------------------------
# Must match the slot created by init-primary.sh and the application
# name referenced by postgresql.primary.conf's synchronous_standby_names.
REPLICATION_SLOT_NAME=omnisight_standby_slot
REPLICATION_APPLICATION_NAME=omnisight_standby

# --- Host-side port mapping (avoid collision with local Postgres) -----
PG_PRIMARY_HOST_PORT=5432
PG_STANDBY_HOST_PORT=5433

# --- Standby bootstrap timeout ----------------------------------------
# Seconds to wait for the primary to accept connections before the
# standby gives up on pg_basebackup during first boot.
STANDBY_BASEBACKUP_TIMEOUT=300

# --- Operator knob: synchronous replication ---------------------------
# OmniSight defaults to ASYNCHRONOUS streaming replication (empty
# synchronous_standby_names). To make replication SYNCHRONOUS (primary
# COMMIT waits for standby flush — higher durability, higher latency):
#
#   1. Edit deploy/postgres-ha/postgresql.primary.conf
#   2. Set: synchronous_standby_names = 'FIRST 1 (omnisight_standby)'
#   3. docker compose -f deploy/postgres-ha/docker-compose.yml exec pg-primary pg_ctl reload
#
# `synchronous_commit = on` (the default in postgresql.primary.conf)
# controls primary-side durability; combined with a non-empty
# synchronous_standby_names it becomes true synchronous replication.
