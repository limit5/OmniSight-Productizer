        "type": "datasource"
      },
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(omnisight_backend_instance_up, instance_id)",
        "hide": 0,
        "includeAll": true,
        "label": "Instance",
