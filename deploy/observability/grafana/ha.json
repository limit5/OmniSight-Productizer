      },
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(omnisight_replica_lag_seconds, replica)",
        "hide": 0,
        "includeAll": true,
        "label": "Replica",
        "multi": true,
        "name": "replica",
        "options": [],
        "query": {
          "query": "label_values(omnisight_replica_lag_seconds, replica)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "OmniSight HA-07 Observability",
  "uid": "omnisight-ha-07",
  "version": 1,
  "weekStart": ""
}
