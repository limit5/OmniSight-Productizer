# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# N1: single-lockfile policy — pnpm is canonical, block npm/yarn lockfiles
package-lock.json
yarn.lock

# next.js
/.next/
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
# Operator's screenshot drop zone (used by Claude Code conversations
# to pass images into context). Nothing in here is meant to be tracked.
debug/

# env files (keep .env.example + .env.test tracked — safe defaults only)
.env*
!.env.example
!.env.test

# python
backend/.venv/
__pycache__/
*.pyc

# build artifacts
/build/

# SDK auto-discovery cache (cloned vendor SDKs)
/.sdks/

# Backend runtime / artifacts
backend/data/
backend/artifacts/
data/.secret_key

# Claude Code harness scratch
.claude/

# Vitest
/coverage/
/.vitest-cache/

# Pytest / coverage.py — local test + CI shard XML artifacts
.coverage
.coverage.*
coverage-*.xml
/htmlcov/

# Playwright
/test-results/
/playwright-report/
/playwright-report-nightly/
/playwright/.cache/

# agent isolated workspaces
.agent_workspaces/

# generated artifacts
.artifacts/

# Vendor SDK cache
.sdks/

# Credential files (keep .example tracked)
configs/ssh_credentials.yaml
configs/git_credentials.yaml

# SQLite database
data/

# pytest
.pytest_cache/

# repomix
repomix-output.xml

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Auto-runner orchestration (local only, not part of the product)
/auto-runner.py
/auto_runner.py

# W2 #276 — Lighthouse CI / web simulator transient output
.lighthouseci/
.lighthouse-report.json
# Playwright runtime cache (spec fixtures under configs/web/ are tracked)
test-results/

# G3 HA-03 blue-green runtime breadcrumbs (state files written by the
# row 1355 ceremony + row 1356 rollback at deploy-time; the symlink
# target + upstream-*.caddy snippets + initial active_color ARE
# tracked so a fresh checkout has a consistent initial state).
deploy/blue-green/previous_color
deploy/blue-green/cutover_timestamp
deploy/blue-green/previous_retention_until

# G4 #5 — db-engine-matrix.yml / pg-live-integration transient output
# (written to the repo root by CI steps; not part of the product).
_dualtrack-*.json
_engine-syntax-scan.json
_pg-live-junit.xml
_migrate-dryrun.json
deploy/blue-green/rollback_timestamp
deploy/blue-green/*.tmp.*

# Phase-3 cutover pre-flight SQLite snapshots (rollback safety net)
backups/
