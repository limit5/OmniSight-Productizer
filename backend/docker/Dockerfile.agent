FROM ubuntu:22.04

LABEL maintainer="OmniSight Engine"
LABEL description="Isolated build environment for OmniSight AI agents"

ENV DEBIAN_FRONTEND=noninteractive

# ── Core build tools ──
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    make \
    cmake \
    python3 \
    python3-pip \
    ca-certificates \
    curl \
    wget \
    # Cross-compilation for aarch64
    gcc-aarch64-linux-gnu \
    g++-aarch64-linux-gnu \
    binutils-aarch64-linux-gnu \
    # Kernel headers for module builds
    linux-libc-dev \
    # Simulation & verification
    valgrind \
    qemu-user-static \
    # Utility
    file \
    tree \
    jq \
    && rm -rf /var/lib/apt/lists/*

# ── RTK (Rust Token Killer) for output compression ──
RUN set -eux; \
    mkdir -p /var/log/omnisight; \
    mkdir -p /root/.claude; \
    RTK_INSTALL_LOG=/var/log/omnisight/rtk-install.log; \
    curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh -o /tmp/rtk-install.sh; \
    sh /tmp/rtk-install.sh >"$RTK_INSTALL_LOG" 2>&1 || { cat "$RTK_INSTALL_LOG" >&2; exit 1; }; \
    ln -sf /root/.local/bin/rtk /usr/local/bin/rtk; \
    rtk --version >>"$RTK_INSTALL_LOG" 2>&1 || { cat "$RTK_INSTALL_LOG" >&2; exit 1; }; \
    rtk init --global >>"$RTK_INSTALL_LOG" 2>&1 || { cat "$RTK_INSTALL_LOG" >&2; exit 1; }; \
    cat "$RTK_INSTALL_LOG"; \
    rm -f /tmp/rtk-install.sh

# ── Git configuration ──
RUN git config --system init.defaultBranch main \
 && git config --system safe.directory '*'

# ── Simulation script ──
COPY scripts/simulate.sh /opt/omnisight/simulate.sh
RUN chmod +x /opt/omnisight/simulate.sh

# ── Working directory ──
WORKDIR /workspace

# Keep container alive for exec-based interaction
CMD ["sleep", "infinity"]
