FROM ubuntu:22.04

LABEL maintainer="OmniSight Engine"
LABEL description="Isolated build environment for OmniSight AI agents"

ENV DEBIAN_FRONTEND=noninteractive

# ── Core build tools ──
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    make \
    cmake \
    python3 \
    python3-pip \
    ca-certificates \
    curl \
    wget \
    # Cross-compilation for aarch64
    gcc-aarch64-linux-gnu \
    g++-aarch64-linux-gnu \
    binutils-aarch64-linux-gnu \
    # Kernel headers for module builds
    linux-libc-dev \
    # Simulation & verification
    valgrind \
    qemu-user-static \
    # Utility
    file \
    tree \
    jq \
    && rm -rf /var/lib/apt/lists/*

# ── RTK (Rust Token Killer) for output compression ──
RUN curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh | sh || true
RUN rtk init --global 2>/dev/null || true

# ── Git configuration ──
RUN git config --system init.defaultBranch main \
 && git config --system safe.directory '*'

# ── Simulation script ──
COPY scripts/simulate.sh /opt/omnisight/simulate.sh
RUN chmod +x /opt/omnisight/simulate.sh

# ── Working directory ──
WORKDIR /workspace

# Keep container alive for exec-based interaction
CMD ["sleep", "infinity"]
