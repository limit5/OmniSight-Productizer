# --- Persistence / migrations -----------------------------------------
aiosqlite==0.21.0
alembic==1.14.0
# G4 Phase-3 wire-up (2026-04-20): PostgreSQL drivers promoted from
# CI-only to production. Earlier revisions kept these out of the
# runtime image to save ~11 MB on wheels the backend-tests /
# openapi-contract / renovate-config jobs didn't need; the cost of
# that optimisation was that G4 [x] never meant "production can
# actually talk to Postgres". ``asyncpg`` is the runtime driver
# used by backend.db_connection::_PostgresAsyncConnection.
# ``psycopg2-binary`` is the sync driver Alembic needs during
# ``alembic upgrade head`` (SQLAlchemy sync engine required, asyncpg
# not supported by Alembic's migration runner). Both stay optional
# from a CODE perspective — backend.db_connection lazy-imports them
# only when the target URL is a ``postgresql+*`` scheme; the plain
# SQLite path keeps working on deployments that don't set
# ``OMNISIGHT_DATABASE_URL``.
asyncpg==0.30.0
psycopg2-binary==2.9.10

# --- Observability ----------------------------------------------------
prometheus-client==0.21.1
structlog==24.4.0
# H1 host-metrics: psutil drives cpu/mem/disk sampling in
# backend/host_metrics.sample_host_once().
psutil==7.2.2
# H1 host-metrics: docker-py SDK is the primary path for
# sample_docker_once() — container count + mem reservation. The module
# soft-imports it and falls back to `docker stats --no-stream`, so this
# pin is strongly recommended (for fidelity) but not strictly required
# (Docker Desktop scenarios already fall through to the CLI).
docker==7.1.0

# --- HTTP client (production runtime; 47 backend modules import it) --
# FX.6.7 (2026-05-04): httpx STAYS here. The TODO entry that landed
# this Phase listed httpx alongside pytest/respx as a "test dep" but
# audit found 47 production modules import it directly at runtime —
# backend/security/oauth_client.py, backend/email_delivery/{postmark,
# ses,resend,http}.py, backend/storage_provisioning/{s3,supabase}.py,
# backend/cms/sanity.py, backend/llm_balance.py, etc. So the prod
# image MUST carry httpx. The dev lockfile (requirements-dev.in) does
# NOT re-pin httpx — pip-tools' ``-c requirements.txt`` constraint
# pins respx's transitive httpx requirement to this version.
httpx==0.28.1

# --- Testing / Lint / Audit (peeled out by FX.6.7 — 2026-05-04) -------
# pytest / pytest-asyncio / pytest-cov / respx / pip-audit / ruff /
# mypy moved to ``backend/requirements-dev.in`` so the prod lockfile
# (``requirements.txt``) stays runtime-only. See that file's header
# for the install pattern + rationale. The Dockerfile no longer needs
# to ``pip uninstall -y pytest …`` after install — those packages are
# never resolved into the prod lockfile in the first place.

